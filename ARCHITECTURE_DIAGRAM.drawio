        <mxCell id="calliope-info" parent="calliope-service" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#000000;" value="Energy System Optimization Engine&#xa;&#xa;Technology:&#xa;• Python-based webservice&#xa;• Linear/Mixed-Integer Programming solver&#xa;• Asynchronous job processing&#xa;&#xa;API Endpoints:&#xa;• POST /api/run - Submit model (multipart form with YAML)&#xa;• GET /api/jobs/:id - Job status &amp;amp; progress&#xa;• GET /api/jobs/:id/results - Optimization results&#xa;&#xa;Input Format:&#xa;• model.yaml - Main model definition&#xa;• locations.yaml - Nodes &amp;amp; technologies&#xa;• techs.yaml - Technology parameters&#xa;&#xa;Output:&#xa;• Optimal capacity decisions&#xa;• Energy flows&#xa;• Cost breakdown&#xa;• System metrics" vertex="1">
          <mxGeometry height="230" width="540" x="10" y="30" as="geometry" />
        </mxCell>
