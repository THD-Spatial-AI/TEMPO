{
  "name": "calliope_visualizator",
  "private": true,
  "version": "0.0.0",
  "description": "Energy System Optimization Visualizer with Calliope Integration",
  "author": "TH Deggendorf",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "npm run build && electron-builder",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.calliope.visualizator",
    "productName": "TEMPO",
    "directories": {
      "output": "C:\\temp\\calliope-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend-go/**/*",
      "python/**/*",
      "solvers/**/*"
    ],
    "asarUnpack": [
      "backend-go/**/*",
      "python/**/*",
      "solvers/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.5",
    "@deck.gl/layers": "^9.2.5",
    "@deck.gl/react": "^9.2.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "apexcharts": "^5.3.6",
    "clsx": "^2.1.1",
    "deck.gl": "^9.2.5",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "electron-store": "^11.0.2",
    "file-saver": "^2.0.5",
    "flatpickr": "^4.6.13",
    "framer-motion": "^12.23.27",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "maplibre-gl": "^5.16.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-apexcharts": "^1.9.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-map-gl": "^8.1.0",
    "react-spring": "^10.0.3",
    "react-use-measure": "^2.1.7",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4",
    "wait-on": "^9.0.4"
  }
}
