          const distance = calculateDistance(
            linkStart.latitude,
            linkStart.longitude,
            location.latitude,
            location.longitude
          );
          
          const newLink = {
            id: Date.now(),
            from: linkStart.id,
            to: location.id,
            fromName: linkStart.name,
            toName: location.name,
            distance: distance
          };
