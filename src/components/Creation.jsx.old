      dialogTechs: Object.keys(location.techs || {})
    });
    setIsNode(location.isNode || false);
    setDialogTechs(Object.keys(location.techs || {}));
    // Pre-populate editing states with existing data
    const existingConstraints = {};
    const existingEssentials = {};
    const existingCosts = {};
    Object.entries(location.techs || {}).forEach(([techName, techData]) => {
      if (techData.constraints) existingConstraints[techName] = techData.constraints;
      if (techData.essentials) existingEssentials[techName] = techData.essentials;
      if (techData.costs?.monetary) existingCosts[techName] = techData.costs.monetary;
    });
    setEditingConstraints(existingConstraints);
    setEditingEssentials(existingEssentials);
    setEditingCosts(existingCosts);
    setShowLocationDialog(true);
  };

  // Remove location
  const removeLocation = (id) => {
    setTempLocations(tempLocations.filter(loc => loc.id !== id));
    setTempLinks(tempLinks.filter(link => link.from !== id && link.to !== id));
  };

  // Remove link
  const removeLink = (id) => {
    setTempLinks(tempLinks.filter(link => link.id !== id));
  };

  // Update location details
  const updateLocation = (id, updates) => {
    setTempLocations(tempLocations.map(loc => 
      loc.id === id ? { ...loc, ...updates } : loc
    ));
  };

  // Add technology to selected location
  const addTechToLocation = (techName) => {
    if (selectedLocation && !selectedLocation.techs[techName]) {
      const techTemplate = techMap[techName];
      const updatedLocation = {
        ...selectedLocation,
        techs: {
          ...selectedLocation.techs,
          [techName]: {
            parent: techTemplate?.parent || 'unknown',
            constraints: techTemplate?.constraints || {},
            costs: techTemplate?.costs || {}
          }
        }
      };
      updateLocation(selectedLocation.id, updatedLocation);
      setSelectedLocation(updatedLocation);
    }
  };

  // Remove technology from selected location
  const removeTechFromLocation = (techName) => {
    if (selectedLocation) {
      const techs = { ...selectedLocation.techs };
      delete techs[techName];
      const updatedLocation = { ...selectedLocation, techs };
      updateLocation(selectedLocation.id, updatedLocation);
      setSelectedLocation(updatedLocation);
    }
  };

  // Confirm location creation from dialog
  const confirmLocationCreation = () => {
    if (!pendingLocation) return;
    
    const locationType = mode === 'single' ? 'single' : mode === 'multiple' ? 'multiple' : (pendingLocation.locationType || 'single');
    
    const finalLocation = {
      ...pendingLocation,
      isNode: isNode,
      locationType: locationType,
      techs: pendingLocation.techs || {}
    };

    // Add selected technologies with their constraints, essentials, costs and CSV files
    dialogTechs.forEach(techName => {
      const techTemplate = techMap[techName];
      const customConstraints = editingConstraints[techName] || {};
      const customEssentials = editingEssentials[techName] || {};
      const customCosts = editingCosts[techName] || {};
      
      finalLocation.techs[techName] = {
        parent: techTemplate?.parent || 'unknown',
        essentials: { ...techTemplate?.essentials, ...customEssentials },
        constraints: { ...techTemplate?.constraints, ...customConstraints },
        costs: {
          monetary: { ...(techTemplate?.costs?.monetary || {}), ...customCosts }
        },
        csvFile: techCsvFiles[techName] || null
      };
    });

    // Validate based on location type
    if (locationType === 'single' && dialogTechs.length > 1 && !isNode) {
      showNotification('Single location can only have one technology', 'warning');
      return;
    }

    // Check if editing existing location
    if (tempLocations.find(l => l.id === pendingLocation.id)) {
      setTempLocations(tempLocations.map(l => l.id === pendingLocation.id ? finalLocation : l));
      showNotification(`Location "${finalLocation.name}" updated successfully`, 'success');
    } else {
      setTempLocations([...tempLocations, finalLocation]);
      showNotification(`Location "${finalLocation.name}" created successfully`, 'success');
    }

    setShowLocationDialog(false);
    setPendingLocation(null);
    setOriginalLocationData(null);
    setDialogTechs([]);
    setEditingConstraints({});
    setEditingEssentials({});
    setEditingCosts({});
    setExpandedTechConstraints({});
    setTechCsvFiles({});
    setConstraintCsvFiles({});
    setConstraintSearch({});
    setCostSearch({});
  };

  // Add technology to dialog list
  const addTechToDialog = (techName) => {
    if (!dialogTechs.includes(techName)) {
      setDialogTechs([...dialogTechs, techName]);
    }
  };

  // Remove technology from dialog list
  const removeTechFromDialog = (techName) => {
    setDialogTechs(dialogTechs.filter(t => t !== techName));
    const newConstraints = { ...editingConstraints };
    delete newConstraints[techName];
    setEditingConstraints(newConstraints);
    
    const newExpanded = { ...expandedTechConstraints };
    delete newExpanded[techName];
    setExpandedTechConstraints(newExpanded);
    
    const newCsvFiles = { ...techCsvFiles };
    delete newCsvFiles[techName];
    setTechCsvFiles(newCsvFiles);
  };

  // Check if location has been modified
  const hasLocationChanged = () => {
    if (!originalLocationData) return true; // New location, always allow creation
    
    // Check basic properties
    if (pendingLocation.latitude !== originalLocationData.latitude) return true;
    if (pendingLocation.longitude !== originalLocationData.longitude) return true;
    if (pendingLocation.name !== originalLocationData.name) return true;
    if (isNode !== originalLocationData.isNode) return true;
    
    // Check if technologies list changed
    const currentTechs = [...dialogTechs].sort();
    const originalTechs = [...originalLocationData.dialogTechs].sort();
    if (JSON.stringify(currentTechs) !== JSON.stringify(originalTechs)) return true;
    
    // Check if any technology's constraints, essentials, or costs changed
    for (const techName of dialogTechs) {
      const originalTech = originalLocationData.techs[techName];
      const currentConstraints = editingConstraints[techName] || {};
      const currentEssentials = editingEssentials[techName] || {};
      const currentCosts = editingCosts[techName] || {};
      
      if (originalTech) {
        // Compare constraints
        if (JSON.stringify(currentConstraints) !== JSON.stringify(originalTech.constraints || {})) return true;
        // Compare essentials
        if (JSON.stringify(currentEssentials) !== JSON.stringify(originalTech.essentials || {})) return true;
        // Compare costs
        if (JSON.stringify(currentCosts) !== JSON.stringify(originalTech.costs?.monetary || {})) return true;
      } else {
        // New technology added
        return true;
      }
    }
    
    return false;
  };

  // Update constraint for a technology in dialog
  const updateDialogConstraint = (techName, key, value) => {
    setEditingConstraints({
      ...editingConstraints,
      [techName]: {
        ...(editingConstraints[techName] || {}),
        [key]: isNaN(value) || value === '' ? value : parseFloat(value)
      }
    });
  };

  // Update essential for a technology
  const updateDialogEssential = (techName, key, value) => {
    setEditingEssentials({
      ...editingEssentials,
      [techName]: {
        ...(editingEssentials[techName] || {}),
        [key]: value
      }
    });
  };

  // Update cost for a technology
  const updateDialogCost = (techName, key, value) => {
    setEditingCosts({
      ...editingCosts,
      [techName]: {
        ...(editingCosts[techName] || {}),
        [key]: isNaN(value) || value === '' ? value : parseFloat(value)
      }
    });
  };

  // Add new constraint to technology in dialog
  const addDialogConstraint = (techName) => {
    if (newConstraintKey.trim()) {
      updateDialogConstraint(techName, newConstraintKey, newConstraintValue);
      setNewConstraintKey('');
      setNewConstraintValue('');
    }
  };

  const handleTechCsvUpload = (techName, file) => {
    if (file && file.name.endsWith('.csv')) {
      setTechCsvFiles({
        ...techCsvFiles,
        [techName]: file
      });
    }
  };

  const handleConstraintCsvUpload = (techName, constraintKey, file) => {
    if (file && file.name.endsWith('.csv')) {
      const fileKey = `${techName}_${constraintKey}`;
      setConstraintCsvFiles({
        ...constraintCsvFiles,
        [fileKey]: file
      });
      // Update the constraint value to indicate file is used
      updateDialogConstraint(techName, constraintKey, `file:${file.name}`);
    }
  };

  // Process CSV files and add to timeSeries
  const processUploadedCsvFiles = async (locationName) => {
    const Papa = (await import('papaparse')).default;
    const newTimeSeries = [];

    // Process technology CSV files (production/consumption)
    for (const [techName, file] of Object.entries(techCsvFiles)) {
      if (file) {
        await new Promise((resolve) => {
          Papa.parse(file, {
            header: true,
            dynamicTyping: true,
            skipEmptyLines: true,
            complete: (results) => {
              newTimeSeries.push({
                id: `${Date.now()}_${techName}_${Math.random()}`,
                name: file.name,
                fileName: file.name,
                uploadedAt: new Date().toISOString(),
                data: results.data,
                columns: results.meta.fields || [],
                rowCount: results.data.length,
                location: locationName,
                technology: techName,
                type: 'production_consumption'
              });
              resolve();
            }
          });
        });
      }
    }

    // Process constraint CSV files (resource)
    for (const [fileKey, file] of Object.entries(constraintCsvFiles)) {
      if (file) {
        const [techName, constraintKey] = fileKey.split('_');
        await new Promise((resolve) => {
          Papa.parse(file, {
            header: true,
            dynamicTyping: true,
            skipEmptyLines: true,
            complete: (results) => {
              newTimeSeries.push({
                id: `${Date.now()}_${fileKey}_${Math.random()}`,
                name: file.name,
                fileName: file.name,
                uploadedAt: new Date().toISOString(),
                data: results.data,
                columns: results.meta.fields || [],
                rowCount: results.data.length,
                location: locationName,
                technology: techName,
                constraintType: constraintKey,
                type: 'constraint'
              });
              resolve();
            }
          });
        });
      }
    }

    return newTimeSeries;
  };

  const toggleTechConstraints = (techName) => {
    setExpandedTechConstraints({
      ...expandedTechConstraints,
      [techName]: !expandedTechConstraints[techName]
    });
  };

  // Save to main data
  const saveToMainData = async () => {
    if (!modelName.trim()) {
      showNotification('Please enter a model name', 'warning');
      return;
    }

    // Process all CSV files from all locations
    const allNewTimeSeries = [];
    
    for (const loc of tempLocations) {
      if (loc.techs) {
        for (const [techName, techData] of Object.entries(loc.techs)) {
          // Process technology production/consumption CSV
          if (techData.csvFile) {
            const Papa = (await import('papaparse')).default;
            await new Promise((resolve) => {
              Papa.parse(techData.csvFile, {
                header: true,
                dynamicTyping: true,
                skipEmptyLines: true,
                complete: (results) => {
                  allNewTimeSeries.push({
                    id: `${Date.now()}_${loc.name}_${techName}_prod_${Math.random()}`,
                    name: techData.csvFile.name,
                    fileName: techData.csvFile.name,
                    uploadedAt: new Date().toISOString(),
                    data: results.data,
                    columns: results.meta.fields || [],
                    rowCount: results.data.length,
                    location: loc.name,
                    technology: techName,
                    type: 'production_consumption'
                  });
                  resolve();
                }
              });
            });
          }
          
          // Process constraint CSV files (check for file: prefix in constraint values)
          if (techData.constraints) {
            for (const [constraintKey, constraintValue] of Object.entries(techData.constraints)) {
              if (typeof constraintValue === 'string' && constraintValue.startsWith('file:')) {
                // Find the actual file from constraintCsvFiles state
                // Note: This won't work after dialog closes, so we need a better approach
                // For now, we'll just mark it in the constraint value
              }
            }
          }
        }
      }
    }

    // Add new timeseries to existing ones
    if (allNewTimeSeries.length > 0) {
      setTimeSeries([...timeSeries, ...allNewTimeSeries]);
    }

    // Convert temp locations to final format
    const finalLocations = tempLocations.map(loc => ({
      name: loc.name,
      latitude: loc.latitude,
      longitude: loc.longitude,
      type: loc.isNode ? 'node' : 'site',
      coordinates: {
        lat: loc.latitude,
        lon: loc.longitude
      },
      techs: loc.techs || {},
      available_techs: Object.keys(loc.techs || {}).join(',')
    }));

    // Convert temp links to final format
    const finalLinks = tempLinks.map(link => {
      const fromLoc = tempLocations.find(l => l.id === link.from);
      const toLoc = tempLocations.find(l => l.id === link.to);
      return {
        from: fromLoc.name,
        to: toLoc.name,
        distance: link.distance,
        techs: {}
      };
    });

    // Collect all unique technologies
    const techsToAdd = [];
    tempLocations.forEach(loc => {
      if (loc.techs) {
        Object.entries(loc.techs).forEach(([techName, techData]) => {
          if (!techsToAdd.find(t => t.name === techName)) {
            const template = techMap[techName];
            if (template) {
              techsToAdd.push({
                ...template,
                name: techName,
                constraints: { ...template.constraints, ...techData.constraints },
                costs: { ...template.costs, ...techData.costs },
                essentials: { ...template.essentials, ...techData.essentials }
              });
            }
          }
        });
      }
    });

    // Create new model
    createModel(
      modelConfig.name || modelName.trim(),
      finalLocations,
      finalLinks,
      [],
      techsToAdd,
      [], // timeSeriesData - empty array for now
      {
        description: `Model created in Creation mode with ${tempLocations.length} locations and ${tempLinks.length} links`,
        createdInCreationMode: true,
        modelConfig: {
          calliopeVersion: modelConfig.calliopeVersion,
          startDate: modelConfig.startDate,
          endDate: modelConfig.endDate,
          solver: modelConfig.solver,
          ensureFeasibility: modelConfig.ensureFeasibility,
          cyclicStorage: modelConfig.cyclicStorage,
          mode: modelConfig.mode,
          objectiveCostClass: modelConfig.objectiveCostClass,
          solverOptions: modelConfig.solverOptions
        }
      }
    );
    
    showNotification(`Model "${modelConfig.name || modelName}" created successfully!`, 'success');
    
    // Reset creation state
    setTempLocations([]);
    setTempLinks([]);
    setLinkStart(null);
    setSelectedLocation(null);
    setModelName('');
    setShowSaveDialog(false);
  };

  // Clear all
  const clearAll = () => {
    if (window.confirm('Clear all unsaved locations and links?')) {
      setTempLocations([]);
      setTempLinks([]);
      setLinkStart(null);
      setSelectedLocation(null);
    }
  };

  // Generate power mesh from OSM power lines
  const generateMeshFromLines = useCallback(() => {
    if (!osmPowerLines) {
      showNotification('Please load OSM power lines data first', 'warning');
      return;
    }

    console.log('🔧 Generating power mesh from OSM data...');
    
    // Generate mesh with current filters
    const meshOptions = {
      deduplicationThreshold: 0.5, // 500m radius for merging nearby points
      snapThreshold: 0.5, // 500m radius for snapping line endpoints to nodes
      minVoltage: powerLineFilters.minVoltage,
      maxVoltage: powerLineFilters.maxVoltage
    };

    const result = generatePowerMesh(osmPowerLines, meshOptions);

    if (result.success) {
      setGeneratedMesh(result);
      setMeshVisible(true);
      
      // Validate mesh
      const validation = validateMesh(result);
      if (!validation.valid) {
        console.error('Mesh validation errors:', validation.issues);
        showNotification('Mesh generated with errors. Check console for details.', 'warning');
      } else if (validation.warnings.length > 0) {
        console.warn('Mesh validation warnings:', validation.warnings);
      }

      showNotification(
        `✅ ${result.message}\n📊 Stats: ${result.statistics.avgConnectivity} avg connections, ${result.statistics.isolatedNodes} isolated nodes`,
        'success'
      );
    } else {
      showNotification(`Failed to generate mesh: ${result.message}`, 'error');
    }
  }, [osmPowerLines, powerLineFilters, showNotification]);

  // Convert mesh to Calliope locations
  const importMeshAsLocations = useCallback(() => {
    if (!generatedMesh) {
      showNotification('No mesh generated yet', 'warning');
      return;
    }

    // Use a base timestamp for all IDs in this import to avoid conflicts
    const baseTimestamp = Date.now();
    const meshLocations = generatedMesh.nodes.map((node, index) => ({
      id: baseTimestamp + index, // Unique timestamp-based ID
      name: node.name,
      latitude: node.latitude,
      longitude: node.longitude,
      techs: {}, // Empty by default, can be assigned later via edit dialog
      isNode: false, // Keep as regular circle, not triangle
      metadata: {
        meshNodeId: node.id,
        voltage: node.voltage,
        clusterSize: node.clusterSize,
        alternativeNames: node.alternativeNames || [],
        importedFromMesh: true
      }
    }));
    
    // Replace temp locations (not append) to avoid overlapping
    setTempLocations(meshLocations);
    
    // Create a map of mesh node IDs to location IDs for link creation
    const nodeIdToLocationId = {};
    generatedMesh.nodes.forEach((node, index) => {
      nodeIdToLocationId[node.id] = baseTimestamp + index;
    });
    
    // Add mesh edges as links, using real distance from OSM power lines if available
    const meshLinks = generatedMesh.edges.map((edge, index) => {
      const fromLocationId = nodeIdToLocationId[edge.from];
      const toLocationId = nodeIdToLocationId[edge.to];
      const fromNode = generatedMesh.nodes.find(n => n.id === edge.from);
      const toNode = generatedMesh.nodes.find(n => n.id === edge.to);
      // Use realDistance (actual OSM line distance) if available, otherwise fall back to straight-line distance
      const linkDistance = edge.realDistance || edge.distance;
      return {
        id: baseTimestamp + 100000 + index, // Unique timestamp-based ID for link
        from: fromLocationId,
        to: toLocationId,
        fromName: fromNode.name,
        toName: toNode.name,
        distance: linkDistance.toFixed(2),
        realDistance: edge.realDistance ? edge.realDistance.toFixed(2) : null,  // Store real distance separately
        straightDistance: edge.distance.toFixed(2),  // Store straight-line distance for reference
        techs: {} // Empty techs object, can be assigned later
      };
    });

    // Replace temp links (not append) to avoid duplicates
    setTempLinks(meshLinks);
    
    // Clear the mesh after importing to avoid re-importing
    setGeneratedMesh(null);
    
    console.log('Imported mesh locations:', meshLocations.length, 'Sample:', meshLocations[0]);
    console.log('Imported mesh links:', meshLinks.length, 'Sample:', meshLinks[0]);
    
    showNotification(
      `Imported ${meshLocations.length} locations and ${meshLinks.length} links from mesh. Previous data cleared.`,
      'success'
    );
  }, [generatedMesh, showNotification]);

  // Export mesh to JSON
  const exportMesh = useCallback(() => {
    if (!generatedMesh) {
      showNotification('No mesh generated yet', 'warning');
      return;
    }

    const json = exportMeshToJson(generatedMesh);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `power_mesh_${Date.now()}.json`;
    link.click();
    URL.revokeObjectURL(url);

    showNotification('Mesh exported successfully', 'success');
  }, [generatedMesh, showNotification]);

  // Add edge between two mesh nodes
  const addMeshEdge = useCallback((fromNodeId, toNodeId) => {
    if (!generatedMesh) return;

    const fromNode = generatedMesh.nodes.find(n => n.id === fromNodeId);
    const toNode = generatedMesh.nodes.find(n => n.id === toNodeId);

    if (!fromNode || !toNode || fromNodeId === toNodeId) {
      showNotification('Invalid nodes selected for edge creation', 'warning');
      return;
    }

    // Check if edge already exists
    const edgeExists = generatedMesh.edges.some(
      e => (e.from === fromNodeId && e.to === toNodeId) || 
           (e.from === toNodeId && e.to === fromNodeId)
    );

    if (edgeExists) {
      showNotification('Edge already exists between these nodes', 'warning');
      return;
    }

    // Calculate distance between nodes
    const distance = calculateDistance(
      fromNode.latitude,
      fromNode.longitude,
      toNode.latitude,
      toNode.longitude
    );

    // Create new edge
    const newEdge = {
      id: `edge_manual_${Date.now()}`,
      from: fromNodeId,
      to: toNodeId,
      fromNode: fromNode,
      toNode: toNode,
      voltage: Math.max(fromNode.voltage || 0, toNode.voltage || 0),
      distance: distance,
      lineId: 'manual',
      properties: { manual: true }
    };

    // Update mesh
    setGeneratedMesh({
      ...generatedMesh,
      edges: [...generatedMesh.edges, newEdge],
      statistics: calculateMeshStatistics({
        nodes: generatedMesh.nodes,
        edges: [...generatedMesh.edges, newEdge]
      })
    });

    showNotification('Edge added successfully', 'success');
  }, [generatedMesh, showNotification]);

  // Remove edge from mesh
  const removeMeshEdge = useCallback((edgeId) => {
    if (!generatedMesh) return;

    const updatedEdges = generatedMesh.edges.filter(e => e.id !== edgeId);

    setGeneratedMesh({
      ...generatedMesh,
      edges: updatedEdges,
      statistics: calculateMeshStatistics({
        nodes: generatedMesh.nodes,
        edges: updatedEdges
      })
    });

    showNotification('Edge removed successfully', 'success');
  }, [generatedMesh, showNotification]);

  // Update mesh node properties
  const updateMeshNode = useCallback((nodeId, updates) => {
    if (!generatedMesh) return;

    const updatedNodes = generatedMesh.nodes.map(node => 
      node.id === nodeId ? { ...node, ...updates } : node
    );

    setGeneratedMesh({
      ...generatedMesh,
      nodes: updatedNodes
    });

    // Update selected node if it's the one being modified
    if (selectedMeshNode?.id === nodeId) {
      setSelectedMeshNode({ ...selectedMeshNode, ...updates });
    }

    showNotification('Node updated successfully', 'success');
  }, [generatedMesh, selectedMeshNode, showNotification]);

  // Make functions available globally for UI buttons
  useEffect(() => {
    window.generateMeshFromLines = generateMeshFromLines;
    window.importMeshAsLocations = importMeshAsLocations;
    window.exportMesh = exportMesh;
    window.generatedMeshExists = !!generatedMesh;
    window.meshStatistics = generatedMesh?.statistics || null;
    window.toggleMeshVisibility = () => setMeshVisible(prev => !prev);
    window.clearMesh = () => {
      setGeneratedMesh(null);
      setMeshVisible(false);
      setSelectedMeshNode(null);
      showNotification('Mesh cleared successfully', 'success');
    };
    
    return () => {
      delete window.generateMeshFromLines;
      delete window.importMeshAsLocations;
      delete window.exportMesh;
      delete window.generatedMeshExists;
      delete window.meshStatistics;
      delete window.toggleMeshVisibility;
      delete window.clearMesh;
    };
  }, [generateMeshFromLines, importMeshAsLocations, exportMesh, generatedMesh]);

  // Map control handlers
  const handleZoomIn = () => {
    setViewState(prev => ({
      ...prev,
      zoom: prev.zoom + 1,
      transitionDuration: 300
    }));
  };

  const handleZoomOut = () => {
    setViewState(prev => ({
      ...prev,
      zoom: prev.zoom - 1,
      transitionDuration: 300
    }));
  };

  const handleSearchLocationSelect = (location) => {
    setViewState(prev => ({
      ...prev,
      longitude: location.longitude,
      latitude: location.latitude,
      zoom: 12,
      transitionDuration: 1000
    }));
  };

  // Handle node checkbox change with confirmation
  const handleNodeCheckboxChange = (checked) => {
    if (checked && dialogTechs.length > 0) {
      // Show custom confirmation dialog if there are technologies
      setShowNodeConfirmDialog(true);
    } else {
      setIsNode(checked);
    }
  };

  // Confirm node conversion and clear technologies
  const confirmNodeConversion = () => {
    setIsNode(true);
    setDialogTechs([]);
    setEditingConstraints({});
    setEditingEssentials({});
    setEditingCosts({});
    setTechCsvFiles({});
    setConstraintCsvFiles({});
    setPendingLocation({ ...pendingLocation, techs: {} });
    setShowNodeConfirmDialog(false);
  };

  // Global data panel handlers
  const handleGlobalDataLoaded = (plants) => {
    setGlobalPowerPlants(plants);
  };

  const handleCountrySelect = async (country, loadBoundaries = false) => {
    setSelectedCountry(country);
    
    if (loadBoundaries && country) {
      // Load country boundaries from Natural Earth or other GeoJSON sources
      try {
        // For now, we'll use a simplified approach
        // In production, you'd fetch from a GeoJSON API like:
        // https://raw.githubusercontent.com/datasets/geo-boundaries-world-110m/master/countries.geojson
        const response = await fetch(`https://raw.githubusercontent.com/datasets/geo-boundaries-world-110m/master/countries.geojson`);
        const geojson = await response.json();
        
        // Filter for selected country
        const countryFeature = geojson.features.filter(f => 
          f.properties.name === country || f.properties.ADMIN === country
        );
        
        setCountryBoundaries({
          type: 'FeatureCollection',
          features: countryFeature
        });
      } catch (error) {
        console.error('Error loading country boundaries:', error);
        showNotification?.('Could not load country boundaries', 'error');
      }
    } else {
      setCountryBoundaries(null);
    }
  };

  const handleAdminSelect = async (level) => {
    setAdminLevel(level);
    
    if (level !== 'country' && selectedCountry) {
      // Load administrative boundaries
      // This would require a more detailed GeoJSON source
      // For now, we'll just set the level
      showNotification?.(`Admin level changed to: ${level}. Boundary data loading not yet implemented.`, 'info');
    }
  };

  // Convert power plant to editable location
  const handlePowerPlantClick = (plant) => {
    if (!plant) return;
    
    // Check if already converted
    const existingIndex = tempLocations.findIndex(loc => 
      loc.isPowerPlant && loc.sourceId === plant.gppd_idnr
    );
    if (existingIndex >= 0) {
      // Already converted, select it for editing
      setSelectedLocation(tempLocations[existingIndex]);
      return;
    }
    
    // Map fuel type to technology template
    const fuelType = plant.primary_fuel?.toLowerCase() || '';
    let techName = 'power_generation';
    
    // Try to match with existing technology templates
    if (fuelType.includes('solar')) techName = 'solar_pv';
    else if (fuelType.includes('wind')) techName = 'wind_onshore';
    else if (fuelType.includes('hydro')) techName = 'hydro_reservoir';
    else if (fuelType.includes('nuclear')) techName = 'nuclear';
    else if (fuelType.includes('gas')) techName = 'gas_ccgt';
    else if (fuelType.includes('coal')) techName = 'coal';
    else if (fuelType.includes('oil')) techName = 'oil';
    else if (fuelType.includes('biomass')) techName = 'biomass';
    else if (fuelType.includes('geothermal')) techName = 'geothermal';
    
    // Convert power plant to location format
    const newLocation = {
      id: `plant_${Date.now()}_${Math.random()}`,
      sourceId: plant.gppd_idnr,
      name: plant.name || 'Unnamed Plant',
      latitude: parseFloat(plant.latitude),
      longitude: parseFloat(plant.longitude),
      isNode: false,
      isPowerPlant: true,
      techs: {
        [techName]: {
          constraints: {
            energy_cap_max: (parseFloat(plant.capacity_mw) || 10) * 1000, // Convert MW to kW
            energy_eff: 0.9
          },
          costs: {
            monetary: {
              energy_cap: 1000,
              om_annual: 50
            }
          }
        }
      },
      metadata: {
        fuel: plant.primary_fuel,
        capacityMW: parseFloat(plant.capacity_mw),
        owner: plant.owner,
        commissioningYear: plant.commissioning_year,
        country: plant.country_long
      }
    };
    
    // Add to tempLocations
    setTempLocations(prev => [...prev, newLocation]);
    setSelectedLocation(newLocation);
    showNotification?.(`Added ${plant.name} as editable location. You can now add more technologies.`, 'success');
  };

  // Handle dragging power plant locations
  const handlePowerPlantDrag = (plantId, newLat, newLon) => {
    setPowerPlantAsLocations(prev => prev.map(plant => 
      plant.id === plantId 
        ? { ...plant, latitude: newLat, longitude: newLon }
        : plant
    ));
    setTempLocations(prev => prev.map(loc =>
      loc.id === plantId
        ? { ...loc, latitude: newLat, longitude: newLon }
        : loc
    ));
  };

  // Handle running Calliope model
  const handleRunModel = async () => {
    if (tempLocations.length === 0) {
      alert('Please add at least one location before running the model');
      return;
    }

    if (!modelConfig.name || modelConfig.name.trim() === '') {
      alert('Please provide a model name in the configuration section');
      return;
    }

    setIsRunningModel(true);
    setJobProgress(0);
    setModelResults(null);

    try {
      // Prepare model data
      const modelData = {
        name: modelConfig.name,
        calliope_version: modelConfig.calliopeVersion,
        timeseries: {
          start_date: modelConfig.startDate,
          end_date: modelConfig.endDate
        },
        run: {
          mode: modelConfig.mode,
          solver: modelConfig.solver,
          ensure_feasibility: modelConfig.ensureFeasibility,
          cyclic_storage: modelConfig.cyclicStorage,
          objective_cost_class: modelConfig.objectiveCostClass,
          solver_options: modelConfig.solverOptions
        },
        locations: tempLocations.map(loc => ({
          id: loc.id,
          name: loc.name,
          latitude: loc.latitude,
          longitude: loc.longitude,
          technologies: loc.techs.map(t => t.name),
          constraints: {}
        })),
        links: tempLinks.map(link => ({
          id: link.id,
          source: link.source,
          target: link.target,
          distance: link.distance || calculateDistance(
            tempLocations.find(l => l.id === link.source),
            tempLocations.find(l => l.id === link.target)
          ),
          technology: link.tech || 'transmission',
          constraints: {}
        })),
        technologies: technologies.map(tech => ({
          name: tech.name,
          type: tech.type,
          carrier: tech.carrier,
          carrier_in: tech.carrier_in || [],
          carrier_out: tech.carrier_out || [],
          constraints: tech.constraints || {}
        }))
      };

      // Save model
      const { id: modelId } = await api.saveModel(modelData);
      console.log(`Model saved with ID: ${modelId}`);

      // Run optimization
      const { job_id } = await api.runModel(modelId);
      setCurrentJob(job_id);
      console.log(`Job started with ID: ${job_id}`);

      // Poll for results
      const results = await api.pollJob(job_id, (job) => {
        setJobProgress(job.progress);
        console.log(`Job progress: ${job.progress}%`);
      });

      setModelResults(results);
      setIsRunningModel(false);
      alert('Model optimization completed successfully!');
      
    } catch (error) {
      console.error('Error running model:', error);
      setIsRunningModel(false);
      alert(`Error running model: ${error.message}`);
    }
  };

  return (
    <div className="flex-1 h-screen overflow-hidden flex">
      {/* Left Panel - Tools */}
      <div 
        className={`bg-white border-r border-slate-200 flex flex-col transition-all duration-300 ${
          leftSidebarCollapsed ? 'w-16' : 'w-80'
        }`}
      >
        {/* Collapse/Expand Button */}
        <div className="p-2 border-b border-slate-200 flex justify-between items-center">
          {!leftSidebarCollapsed && (
            <div>
              <h2 className="text-lg font-bold text-slate-800">Creation Mode</h2>
              <p className="text-xs text-slate-600">Build your system</p>
            </div>
          )}
          <button
            onClick={() => setLeftSidebarCollapsed(!leftSidebarCollapsed)}
            className="p-2 hover:bg-slate-100 rounded-lg transition-colors ml-auto"
            title={leftSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar"}
          >
            {leftSidebarCollapsed ? <FiChevronRight size={20} /> : <FiChevronLeft size={20} />}
          </button>
        </div>

        {!leftSidebarCollapsed ? (
          <>
            {/* Mode Selection */}
            <div className="p-4 border-b border-slate-200 flex-shrink-0">
              <label className="block text-sm font-semibold text-slate-700 mb-2">Mode</label>
              <div className="grid grid-cols-3 gap-2">
                <button
                  onClick={() => setMode('single')}
              className={`p-3 rounded-lg border-2 transition-all ${
                mode === 'single'
                  ? 'border-gray-500 bg-gray-50 text-gray-700'
                  : 'border-slate-200 hover:border-slate-300'
              }`}
            >
              <FiMapPin className="mx-auto mb-1" size={20} />
              <div className="text-xs font-medium">Single</div>
            </button>
            <button
              onClick={() => setMode('multiple')}
              className={`p-3 rounded-lg border-2 transition-all ${
                mode === 'multiple'
                  ? 'border-gray-900 bg-gray-900 text-white'
                  : 'border-slate-200 hover:border-slate-300'
              }`}
            >
              <FiCpu className="mx-auto mb-1" size={20} />
              <div className="text-xs font-medium">Multiple</div>
            </button>
            <button
              onClick={() => {
                setMode('link');
                setLinkStart(null);
              }}
              className={`p-3 rounded-lg border-2 transition-all ${
                mode === 'link'
                  ? 'border-gray-900 bg-gray-900 text-white'
                  : 'border-slate-200 hover:border-slate-300'
              }`}
            >
              <FiLink className="mx-auto mb-1" size={20} />
              <div className="text-xs font-medium">Link</div>
            </button>
          </div>

          {mode === 'single' && (
            <div className="mt-3 p-3 bg-gray-50 rounded-lg text-xs text-gray-700">
              Click to place a location with one technology
            </div>
          )}
          {mode === 'multiple' && (
            <div className="mt-3 p-3 bg-gray-100 rounded-lg text-xs text-gray-900">
              Click to place a location with multiple technologies
            </div>
          )}
          {mode === 'link' && (
            <div className="mt-3 p-3 bg-gray-100 rounded-lg text-xs text-gray-900">
              {linkStart ? 'Click on another location to complete the link' : 'Click on a location to start a link'}
            </div>
          )}
        </div>

        {/* Scrollable Content Area - Contains Configurations and Locations */}
        <div className="flex-1 overflow-y-auto">
          {/* Configurations Section */}
          <div className="border-b border-slate-200">
            <button
              onClick={() => setShowConfigSection(!showConfigSection)}
              className="w-full p-4 flex items-center justify-between hover:bg-slate-50 transition-colors"
            >
            <div className="flex items-center gap-2">
              <FiSettings size={16} className="text-slate-700" />
              <span className="text-sm font-semibold text-slate-700">Configurations</span>
            </div>
            {showConfigSection ? <FiChevronDown size={16} /> : <FiChevronRight size={16} />}
          </button>
          
          {showConfigSection && (
            <div className="p-4 space-y-4 bg-slate-50">
              {/* Model Name */}
              <div>
                <label className="block text-xs font-medium text-slate-700 mb-1">Model Name</label>
                <input
                  type="text"
                  value={modelConfig.name}
                  onChange={(e) => setModelConfig({ ...modelConfig, name: e.target.value })}
                  placeholder="e.g., Chile energy system"
                  className="w-full px-2 py-1.5 text-xs border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                />
              </div>

              {/* Calliope Version */}
              <div>
                <label className="block text-xs font-medium text-slate-700 mb-1">Calliope Version</label>
                <input
                  type="text"
                  value={modelConfig.calliopeVersion}
                  disabled
                  className="w-full px-2 py-1.5 text-xs border border-slate-300 rounded bg-slate-100 text-slate-500 cursor-not-allowed"
                />
              </div>

              {/* Date Range */}
              <div>
                <label className="block text-xs font-medium text-slate-700 mb-2">Date Range</label>
                <div className="space-y-3">
                  <div>
                    <label className="block text-xs text-slate-600 mb-1">Start Date</label>
                    <div className="relative">
                      <input
                        type="date"
                        value={modelConfig.startDate}
                        onChange={(e) => setModelConfig({ ...modelConfig, startDate: e.target.value })}
                        className="w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-gray-500 pr-8"
                        style={{ colorScheme: 'light' }}
                      />
                      <FiCalendar className="absolute right-2 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none" size={16} />
                    </div>
                  </div>
                  <div>
                    <label className="block text-xs text-slate-600 mb-1">End Date</label>
                    <div className="relative">
                      <input
                        type="date"
                        value={modelConfig.endDate}
                        onChange={(e) => setModelConfig({ ...modelConfig, endDate: e.target.value })}
                        min={modelConfig.startDate}
                        className="w-full px-3 py-2 text-sm border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-gray-500 pr-8"
                        style={{ colorScheme: 'light' }}
                      />
                      <FiCalendar className="absolute right-2 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none" size={16} />
                    </div>
                  </div>
                  <div className="text-xs bg-gradient-to-r from-gray-50 to-gray-100 border border-gray-200 rounded-lg p-2">
                    <div className="font-medium text-gray-900">
                      Duration: <span className="font-bold">{Math.ceil((new Date(modelConfig.endDate) - new Date(modelConfig.startDate)) / (1000 * 60 * 60 * 24)) + 1} days</span>
                    </div>
                    <div className="text-gray-700 mt-0.5">
                      {new Date(modelConfig.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} → {new Date(modelConfig.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </div>
                  </div>
                </div>
              </div>

              {/* Solver Selection */}
              <div>
                <label className="block text-xs font-medium text-slate-700 mb-1">Solver</label>
                <select
                  value={modelConfig.solver}
                  onChange={(e) => setModelConfig({ ...modelConfig, solver: e.target.value })}
                  className="w-full px-2 py-1.5 text-xs border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                >
                  <option value="gurobi">Gurobi</option>
                  <option value="cbc">CBC</option>
                  <option value="glpk">GLPK</option>
                  <option value="cplex">CPLEX</option>
                </select>
              </div>

              {/* Mode */}
              <div>
                <label className="block text-xs font-medium text-slate-700 mb-1">Optimization Mode</label>
                <select
                  value={modelConfig.mode}
                  onChange={(e) => setModelConfig({ ...modelConfig, mode: e.target.value })}
                  className="w-full px-2 py-1.5 text-xs border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                >
                  <option value="plan">Plan</option>
                  <option value="operate">Operate</option>
                </select>
              </div>

              {/* Solver Options - Collapsible */}
              <div>
                <button
                  onClick={() => setExpandedSections({ ...expandedSections, solverOptions: !expandedSections.solverOptions })}
                  className="flex items-center justify-between w-full text-xs font-medium text-slate-700 mb-2 hover:text-gray-600"
                >
                  <span>Solver Parameters</span>
                  {expandedSections.solverOptions ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                </button>
                
                {expandedSections.solverOptions && (
                  <div className="space-y-2 pl-2">
                    <div className="grid grid-cols-2 gap-2">
                      <div>
                        <label className="block text-xs text-slate-600 mb-1">Threads</label>
                        <input
                          type="number"
                          value={modelConfig.solverOptions.threads}
                          onChange={(e) => setModelConfig({
                            ...modelConfig,
                            solverOptions: { ...modelConfig.solverOptions, threads: parseInt(e.target.value) || 1 }
                          })}
                          className="w-full px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-500"
                        />
                      </div>
                      <div>
                        <label className="block text-xs text-slate-600 mb-1">Method</label>
                        <input
                          type="number"
                          value={modelConfig.solverOptions.method}
                          onChange={(e) => setModelConfig({
                            ...modelConfig,
                            solverOptions: { ...modelConfig.solverOptions, method: parseInt(e.target.value) || 0 }
                          })}
                          className="w-full px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-500"
                        />
                      </div>
                      <div>
                        <label className="block text-xs text-slate-600 mb-1">MIP Gap</label>
                        <input
                          type="number"
                          step="0.001"
                          value={modelConfig.solverOptions.mipGap}
                          onChange={(e) => setModelConfig({
                            ...modelConfig,
                            solverOptions: { ...modelConfig.solverOptions, mipGap: parseFloat(e.target.value) || 0.001 }
                          })}
                          className="w-full px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-500"
                        />
                      </div>
                      <div>
                        <label className="block text-xs text-slate-600 mb-1">Feasibility Tol</label>
                        <input
                          type="number"
                          step="0.001"
                          value={modelConfig.solverOptions.feasibilityTol}
                          onChange={(e) => setModelConfig({
                            ...modelConfig,
                            solverOptions: { ...modelConfig.solverOptions, feasibilityTol: parseFloat(e.target.value) || 0.001 }
                          })}
                          className="w-full px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-500"
                        />
                      </div>
                    </div>
                    
                    <div className="flex items-center gap-2 pt-2">
                      <input
                        type="checkbox"
                        id="ensureFeasibility"
                        checked={modelConfig.ensureFeasibility}
                        onChange={(e) => setModelConfig({ ...modelConfig, ensureFeasibility: e.target.checked })}
                        className="w-3 h-3 text-gray-600 border-slate-300 rounded focus:ring-gray-500"
                      />
                      <label htmlFor="ensureFeasibility" className="text-xs text-slate-700">Ensure Feasibility</label>
                    </div>
                    
                    <div className="flex items-center gap-2">
                      <input
                        type="checkbox"
                        id="cyclicStorage"
                        checked={modelConfig.cyclicStorage}
                        onChange={(e) => setModelConfig({ ...modelConfig, cyclicStorage: e.target.checked })}
                        className="w-3 h-3 text-gray-600 border-slate-300 rounded focus:ring-gray-500"
                      />
                      <label htmlFor="cyclicStorage" className="text-xs text-slate-700">Cyclic Storage</label>
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>

          {/* Location List or Tech Panel */}
          {mode === 'tech' && selectedLocation ? (
            <div className="border-b border-slate-200">
              <div className="p-4">
              <div className="mb-4">
                <div className="flex items-center justify-between mb-2">
                  <h3 className="font-semibold text-slate-800">{selectedLocation.name}</h3>
                  <button
                    onClick={() => setSelectedLocation(null)}
                    className="text-slate-400 hover:text-slate-600"
                  >
                    <FiX size={18} />
                  </button>
                </div>
                <p className="text-xs text-slate-600">
                  {selectedLocation.latitude.toFixed(4)}, {selectedLocation.longitude.toFixed(4)}
                </p>
              </div>

              <div className="mb-4">
                <label className="block text-sm font-medium text-slate-700 mb-2">
                  Assigned Technologies ({Object.keys(selectedLocation.techs).length})
                </label>
                {Object.keys(selectedLocation.techs).length === 0 ? (
                  <p className="text-xs text-slate-500 italic">No technologies assigned</p>
                ) : (
                  <div className="space-y-2">
                    {Object.keys(selectedLocation.techs).map(techName => (
                      <div
                        key={techName}
                        className="flex items-center justify-between p-2 bg-gray-50 rounded border border-gray-200"
                      >
                        <span className="text-sm font-medium text-gray-900">{formatTechName(techName)}</span>
                        <button
                          onClick={() => removeTechFromLocation(techName)}
                          className="text-gray-500 hover:text-gray-700"
                        >
                          <FiTrash2 size={14} />
                        </button>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <div>
                <label className="block text-sm font-medium text-slate-700 mb-2">
                  Available Technologies
                </label>
                <div className="space-y-2 max-h-96 overflow-y-auto border border-slate-200 rounded-lg p-3">
                  {Object.keys(techMap).length === 0 ? (
                    <div className="text-center py-8 text-slate-500 text-sm">
                      <p>No technologies available.</p>
                    </div>
                  ) : (
                    <>
                      {['supply', 'supply_plus', 'demand', 'storage', 'conversion', 'conversion_plus'].map(parentType => {
                        const techsInCategory = Object.entries(techMap).filter(([name, tech]) => tech.parent === parentType);
                        
                        if (techsInCategory.length === 0) return null;
                        
                        const isExpanded = expandedCategories[`panel_${parentType}`];
                        
                        return (
                          <div key={parentType} className="border border-slate-200 rounded-lg overflow-hidden">
                            <button
                              onClick={() => toggleCategory(`panel_${parentType}`)}
                              className="w-full flex items-center justify-between px-3 py-2 bg-slate-50 hover:bg-slate-100 transition-colors"
                            >
                              <span className="text-xs font-bold text-slate-700 uppercase tracking-wide">
                                {formatTechName(parentType)} ({techsInCategory.length})
                              </span>
                              {isExpanded ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                            </button>
                            
                            {isExpanded && (
                              <div className="p-2 bg-white">
                                <div className="space-y-1">
                                  {techsInCategory.map(([techName, tech]) => {
                                    const isAssigned = selectedLocation.techs[techName];
                                    return (
                                      <button
                                        key={techName}
                                        onClick={() => !isAssigned && addTechToLocation(techName)}
                                        disabled={isAssigned}
                                        className={`w-full text-left p-2 rounded text-xs transition-colors ${
                                          isAssigned
                                            ? 'bg-slate-100 text-slate-400 cursor-not-allowed'
                                            : 'bg-slate-50 hover:bg-gray-50 text-slate-700 hover:text-gray-700 border border-slate-200'
                                        }`}
                                        title={tech.description || techName}
                                      >
                                        {isAssigned ? '✓ ' : '+ '}{formatTechName(techName)}
                                      </button>
                                    );
                                  })}
                                </div>
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </>
                  )}
                </div>
              </div>
            </div>
            </div>
          ) : (
            <div>
            {/* Locations Section */}
            <div className="border-b border-slate-200">
              <button
                onClick={() => setShowLocationsSection(!showLocationsSection)}
                className="w-full p-4 flex items-center justify-between hover:bg-slate-50 transition-colors"
              >
                <div className="flex items-center gap-2">
                  <FiMapPin size={16} className="text-slate-700" />
                  <span className="text-sm font-semibold text-slate-700">Locations ({tempLocations.length})</span>
                </div>
                {showLocationsSection ? <FiChevronDown size={16} /> : <FiChevronRight size={16} />}
              </button>
              
              {showLocationsSection && (
              <div className="p-4 bg-slate-50">
              {tempLocations.length === 0 ? (
                <p className="text-sm text-slate-500 italic">No locations created yet</p>
              ) : (
                <div className="space-y-2">
                  {tempLocations.map(location => (
                    <div
                      key={location.id}
                      onClick={() => setSearchSelectedLocation(location)}
                      className={`p-3 rounded-lg border-2 transition-all cursor-pointer ${
                        linkStart?.id === location.id
                          ? 'border-gray-900 bg-gray-100'
                          : 'border-slate-200 bg-white hover:border-gray-400'
                      }`}
                    >
                      <div className="flex items-start justify-between mb-2">
                        <input
                          type="text"
                          value={location.name}
                          onChange={(e) => updateLocation(location.id, { name: e.target.value })}
                          className="flex-1 px-2 py-1 text-sm font-medium border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                        />
                        <button
                          onClick={() => removeLocation(location.id)}
                          className="ml-2 text-gray-500 hover:text-gray-700"
                        >
                          <FiTrash2 size={16} />
                        </button>
                      </div>

                      <div className="text-xs text-slate-600">
                        📍 {location.latitude.toFixed(4)}, {location.longitude.toFixed(4)}
                      </div>
                      
                      {Object.keys(location.techs).length > 0 && (
                        <div className="mt-2 pt-2 border-t border-slate-200">
                          <div className="text-xs text-slate-600">
                            <FiCpu className="inline mr-1" size={12} />
                            {Object.keys(location.techs).length} tech{Object.keys(location.techs).length !== 1 ? 's' : ''}
                          </div>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              )}
              </div>
              )}
            </div>

            {/* Links Section */}
            {tempLinks.length > 0 && (
              <div className="border-b border-slate-200">
                <button
                  onClick={() => setShowLinksSection(!showLinksSection)}
                  className="w-full p-4 flex items-center justify-between hover:bg-slate-50 transition-colors"
                >
                  <div className="flex items-center gap-2">
                    <FiLink size={16} className="text-slate-700" />
                    <span className="text-sm font-semibold text-slate-700">Links ({tempLinks.length})</span>
                  </div>
                  {showLinksSection ? <FiChevronDown size={16} /> : <FiChevronRight size={16} />}
                </button>
                
                {showLinksSection && (
                <div className="p-4 bg-slate-50">
                  <div className="space-y-2">
                    {tempLinks.map(link => (
                      <div
                        key={link.id}
                        className="p-3 rounded-lg border border-slate-200 bg-white"
                      >
                        <div className="flex items-center justify-between mb-1">
                          <div className="flex-1 text-sm">
                            <div className="font-medium text-slate-800">{link.fromName}</div>
                            <div className="text-slate-400">↓</div>
                            <div className="font-medium text-slate-800">{link.toName}</div>
                          </div>
                          <button
                            onClick={() => removeLink(link.id)}
                            className="text-gray-500 hover:text-gray-700"
                          >
                            <FiTrash2 size={16} />
                          </button>
                        </div>
                        <div className="text-xs text-slate-600">
                          Distance: {link.distance} km
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                )}
              </div>
            )}
            </div>
          )}
        </div>
        {/* Close scrollable content area */}
        </>
        ) : (
          <div className="flex flex-col items-center py-4 gap-4">
            <button
              onClick={() => setMode(mode === 'single' ? null : 'single')}
              className={`p-2 rounded-lg transition-colors ${
                mode === 'single' ? 'bg-blue-500 text-white' : 'hover:bg-slate-100 text-slate-700'
              }`}
              title="Single Location Mode"
            >
              <FiMapPin size={20} />
            </button>
            <button
              onClick={() => setMode(mode === 'multiple' ? null : 'multiple')}
              className={`p-2 rounded-lg transition-colors ${
                mode === 'multiple' ? 'bg-blue-500 text-white' : 'hover:bg-slate-100 text-slate-700'
              }`}
              title="Multiple Locations Mode"
            >
              <FiCpu size={20} />
            </button>
            <button
              onClick={() => setMode(mode === 'link' ? null : 'link')}
              className={`p-2 rounded-lg transition-colors ${
                mode === 'link' ? 'bg-blue-500 text-white' : 'hover:bg-slate-100 text-slate-700'
              }`}
              title="Link Mode"
            >
              <FiLink size={20} />
            </button>
            <div className="border-t border-slate-200 w-8 my-2"></div>
            <button
              onClick={() => setShowSaveDialog(true)}
              disabled={tempLocations.length === 0}
              className="p-2 rounded-lg hover:bg-slate-100 disabled:opacity-50"
              title="Save"
            >
              <FiSave size={20} />
            </button>
          </div>
        )}

        {/* Action Buttons */}
        {!leftSidebarCollapsed && (
        <div className="p-4 border-t border-slate-200 space-y-2 flex-shrink-0">
          <button
            onClick={() => setShowSaveDialog(true)}
            disabled={tempLocations.length === 0}
            className="w-full px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors disabled:bg-slate-300 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <FiSave size={16} />
            Save to Model ({tempLocations.length} locations, {tempLinks.length} links)
          </button>
          <button
            onClick={handleRunModel}
            disabled={tempLocations.length === 0 || isRunningModel}
            className="w-full px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors disabled:bg-slate-300 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <FiPlay size={16} />
            {isRunningModel ? `Running... ${jobProgress}%` : 'Run Model'}
          </button>
          {modelResults && (
            <div className="text-xs text-green-600 font-medium text-center">
              ✓ Model completed successfully!
            </div>
          )}
          <button
            onClick={clearAll}
            disabled={tempLocations.length === 0}
            className="w-full px-4 py-2 border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Clear All
          </button>
        </div>
        )}
      </div>

      {/* Right Panel - Map */}
      <div className="flex-1 relative">
        {/* Map Toolbar */}
        {mapReady && (
          <MapToolbar
            viewport={viewState}
            onViewportChange={setViewState}
            pointSizes={pointSizes}
            onPointSizesChange={setPointSizes}
            lineSizes={lineSizes}
            onLineSizesChange={setLineSizes}
            visibleLayers={layerVisibility}
            onVisibleLayersChange={setLayerVisibility}
            onFitBounds={handleFitBounds}
            onResetView={handleResetView}
            rightSidebarCollapsed={rightSidebarCollapsed}
            locations={tempLocations}
            onLocationSelect={(location) => {
              setViewState({
                ...viewState,
                longitude: location.longitude,
                latitude: location.latitude,
                zoom: 6,
                transitionDuration: 1000,
                transitionInterpolator: new FlyToInterpolator()
              });
            }}
          />
        )}

      {/* Legends - Top Right */}
      {mapReady && (osmPowerLines || osmPowerPlants || osmSubstations) && (layerVisibility.powerLines || layerVisibility.powerPlants || layerVisibility.substations) && (
        <div className={`absolute top-20 z-10 transition-all duration-300 ${
          rightSidebarCollapsed ? 'right-5' : 'right-[20px]'
        }`}>
          <div className="bg-white rounded-lg shadow-lg border border-slate-200 p-2 max-w-[180px]">
            <div className="text-[10px] font-bold text-slate-700 mb-1.5 border-b pb-1">Infrastructure</div>
            
            {/* Power Lines Legend */}
            {osmPowerLines && layerVisibility.powerLines && showOsmLayers.powerLines && (
              <div className="mb-2">
                <div className="text-[9px] font-semibold text-slate-600 mb-1">⚡ Lines</div>
                <div className="space-y-0.5">
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(0, 255, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">≤50 kV</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(100, 255, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">50-110 kV</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(255, 255, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">110-220 kV</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(255, 165, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">220-380 kV</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(255, 0, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">&gt;380 kV</span>
                  </div>
                  <div className="flex items-center gap-1.5">
                    <div className="w-6 h-0.5" style={{ backgroundColor: 'rgb(30, 144, 255)' }}></div>
                    <span className="text-[9px] text-slate-600">Unknown</span>
                  </div>
                </div>
              </div>
            )}
            
            {/* Power Plants Legend */}
            {osmPowerPlants && layerVisibility.powerPlants && showOsmLayers.powerPlants && (
              <div className="mb-2">
                <div className="text-[9px] font-semibold text-slate-600 mb-1">🔋 Plants</div>
                <div className="grid grid-cols-2 gap-x-2 gap-y-0.5">
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(255, 215, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Solar</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(0, 191, 255)' }}></div>
                    <span className="text-[9px] text-slate-600">Wind</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(65, 105, 225)' }}></div>
                    <span className="text-[9px] text-slate-600">Hydro</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(255, 0, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Nuclear</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(255, 140, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Gas</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(105, 105, 105)' }}></div>
                    <span className="text-[9px] text-slate-600">Coal</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(34, 139, 34)' }}></div>
                    <span className="text-[9px] text-slate-600">Biomass</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(128, 128, 128)' }}></div>
                    <span className="text-[9px] text-slate-600">Other</span>
                  </div>
                </div>
              </div>
            )}
            
            {/* Substations Legend */}
            {osmSubstations && layerVisibility.substations && showOsmLayers.substations && (
              <div>
                <div className="text-[9px] font-semibold text-slate-600 mb-1">🔌 Substations</div>
                <div className="grid grid-cols-2 gap-x-2 gap-y-0.5">
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(220, 20, 60)' }}></div>
                    <span className="text-[9px] text-slate-600">Transm.</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(255, 69, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Distrib.</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(255, 0, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Convert.</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(178, 34, 34)' }}></div>
                    <span className="text-[9px] text-slate-600">Traction</span>
                  </div>
                  <div className="flex items-center gap-1">
                    <div className="w-2 h-2 rounded-full" style={{ backgroundColor: 'rgb(139, 0, 0)' }}></div>
                    <span className="text-[9px] text-slate-600">Other</span>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Layer Selector - Bottom Right */}
      {mapReady && (
        <div className={`absolute bottom-4 z-10 transition-all duration-300 ${
          rightSidebarCollapsed ? 'right-5' : 'right-[20px]'
        }`}>
          <div className="relative">
            {/* Compact square button showing current style */}
            <button
              onClick={() => setShowLayerSelector(!showLayerSelector)}
              className="bg-white rounded-lg shadow-lg border border-slate-200 p-3 hover:bg-slate-50 transition-colors"
              title={`Current: ${currentStyle}`}
            >
              {currentStyle === 'streets' && (
                <svg className="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
              )}
              {currentStyle === 'satellite' && (
                <svg className="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
              {currentStyle === 'terrain' && (
                <svg className="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M7 16l-4-4m0 0l4-4m-4 4h18m-5 4l4-4m0 0l-4-4m4 4H3" />
                </svg>
              )}
              {currentStyle === 'dark' && (
                <svg className="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
              )}
            </button>
            
            {/* Horizontal layer options */}
            {showLayerSelector && (
              <div className="absolute bottom-0 right-full mr-2 bg-white rounded-lg shadow-xl border border-slate-200 p-2 flex gap-1">
                {[
                  { name: 'streets', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
                  { name: 'satellite', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
                  { name: 'terrain', icon: 'M7 16l-4-4m0 0l4-4m-4 4h18m-5 4l4-4m0 0l-4-4m4 4H3' },
                  { name: 'dark', icon: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z' }
                ].map(style => (
                  <button
                    key={style.name}
                    onClick={() => {
                      setCurrentStyle(style.name);
                      setShowLayerSelector(false);
                    }}
                    className={`p-3 rounded transition-colors ${
                      currentStyle === style.name
                        ? 'bg-blue-100 text-blue-700'
                        : 'text-slate-700 hover:bg-slate-50'
                    }`}
                    title={style.name.charAt(0).toUpperCase() + style.name.slice(1)}
                  >
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d={style.icon} />
                    </svg>
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>
      )}        {/* Deck.gl Map with WebGL Rendering */}
        {!mapReady ? (
          <div className="w-full h-full flex items-center justify-center bg-slate-50">
            <div className="text-center">
              <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-gray-600 mx-auto mb-4"></div>
              <p className="text-slate-600">Initializing map...</p>
            </div>
          </div>
        ) : (
          <DeckGL
            ref={deckRef}
            viewState={viewState}
            onViewStateChange={({ viewState: newViewState }) => {
              setViewState(newViewState);
              console.log('🔍 Current Zoom Level:', newViewState.zoom.toFixed(2));
            }}
            controller={true}
            onClick={handleMapClick}
            onHover={(info) => {
              // Clear hover info when not hovering over any object
              if (!info.object) {
                setHoveredInfo(null);
              }
            }}
            parameters={{
              depthTest: false,
              blend: true,
              blendFunc: [770, 771],
              blendEquation: 32774
            }}
            _typedArrayManagerProps={{
              overAlloc: 1,
              poolSize: 0
            }}
            pickingRadius={5}
            useDevicePixels={false}
            onError={(error) => {
              // Suppress WebGL context initialization errors
              if (!error?.message?.includes('maxTextureDimension2D')) {
                console.error('Deck.gl error:', error);
              }
            }}
          layers={[
            // Locations layer with pie chart support
            ...(layerVisibility.locations ? [new IconLayer({
              id: 'locations-layer',
              data: tempLocations.filter(loc => loc && loc.longitude && loc.latitude),
              getPosition: d => [d.longitude, d.latitude],
              getIcon: d => {
                try {
                  return createLocationIcon(d, techMap, iconCache.current);
                } catch (error) {
                  console.warn('Error creating icon for location:', d, error);
                  // Return a fallback icon
                  return {
                    url: `data:image/svg+xml;charset=utf-8,${encodeURIComponent(`
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" fill="rgb(148, 163, 184)" stroke="white" stroke-width="2"/>
                      </svg>
                    `)}`,
                    width: 24,
                    height: 24,
                    anchorX: 12,
                    anchorY: 12
                  };
                }
              },
              getSize: d => {
                const techCount = Object.keys(d.techs || {}).length;
                const baseSize = (pointSizes.locations || 8) * 0.5; // Half the original size
                if (d.isNode) return baseSize * 6.25;
                if (techCount > 5) return baseSize * 5.6;
                if (techCount > 0) return baseSize * 5;
                return baseSize * 4.4;
              },
              sizeScale: 1,
              sizeMinPixels: 12,
              sizeMaxPixels: 40,
              pickable: true,
              autoHighlight: false,
              updateTriggers: {
                getIcon: [tempLocations.length, technologies.length],
                getSize: [tempLocations.length]
              },
              onClick: (info, event) => {
                if (info.object) {
                  console.log('Location clicked:', info.object, 'Mode:', mode);
                  if (mode === 'link') {
                    handleLocationClickForLink(info.object);
                    event.stopPropagation();
                  } else {
                    // Allow editing in any mode except link mode
                    console.log('Calling handleEditLocation for:', info.object.name, 'ID:', info.object.id);
                    handleEditLocation(info.object);
                    event.stopPropagation();
                  }
                }
              },
              onHover: (info) => {
                if (info.object) {
                  const techNames = Object.keys(info.object.techs || {});
                  const techList = techNames.length > 0 
                    ? techNames.map(name => {
                        const techDef = techMap[name];
                        return techDef?.description || name;
                      }).join(', ')
                    : 'No technologies';
                  
                  setHoveredInfo({
                    name: info.object.name,
                    techs: techList,
                    x: info.x,
                    y: info.y
                  });
                } else {
                  setHoveredInfo(null);
                }
              }
            })] : []),
            // Links layer
            ...(layerVisibility.links ? [new LineLayer({
              id: 'links-layer',
              data: tempLinks.map(link => {
                const from = tempLocations.find(loc => loc.id === link.from);
                const to = tempLocations.find(loc => loc.id === link.to);
                if (!from || !to) return null;
                return {
                  sourcePosition: [from.longitude, from.latitude],
                  targetPosition: [to.longitude, to.latitude],
                  ...link
                };
              }).filter(Boolean),
              getSourcePosition: d => d.sourcePosition,
              getTargetPosition: d => d.targetPosition,
              getColor: [255, 0, 0, 180],
              getWidth: lineSizes.links || 2,
              pickable: false,
              widthMinPixels: 1,
              antialiasing: false
            })] : []),
            // Country boundaries layer (future enhancement)
            // OSM Power Lines Layer
            ...(osmPowerLines && showOsmLayers.powerLines && layerVisibility.powerLines ? [new GeoJsonLayer({
              id: 'osm-power-lines',
              data: {
                ...osmPowerLines,
                features: osmPowerLines.features.filter(f => {
                  const props = f.properties;
                  
                  // Try to get voltage from voltage_kv (pre-processed) or voltage (raw)
                  let voltage = props.voltage_kv;
                  if (!voltage && props.voltage) {
                    const voltageStr = props.voltage.toString();
                    voltage = parseFloat(voltageStr.replace(/[^0-9.]/g, ''));
                  }
                  
                  // If voltage exists and is a number, apply filter
                  if (voltage && !isNaN(voltage)) {
                    if (voltage < powerLineFilters.minVoltage || voltage > powerLineFilters.maxVoltage) {
                      return false;
                    }
                  }
                  // If no voltage info, still show the line (don't filter out unknowns)
                  
                  return true;
                })
              },
              stroked: true,
              filled: false,
              getLineColor: d => {
                const voltage = d.properties.voltage_kv;
                if (!voltage || voltage === 0) return [30, 144, 255, 220]; // Blue: Unknown
                
                // Green to Red gradient based on voltage (0-500kV range)
                if (voltage <= 50) return [0, 255, 0, 220];        // Green: Very low voltage
                if (voltage <= 110) return [100, 255, 0, 220];     // Yellow-green: Low voltage
                if (voltage <= 220) return [255, 255, 0, 220];     // Yellow: Medium voltage
                if (voltage <= 380) return [255, 165, 0, 220];     // Orange: High voltage
                return [255, 0, 0, 220];                            // Red: Extra high voltage (>380kV)
              },
              getLineWidth: d => {
                const baseWidth = infrastructureSizes.powerLines || 1.0;
                return baseWidth * 1.2;
              },
              lineWidthMinPixels: 1,
              lineWidthMaxPixels: 3,
              pickable: true,
              onHover: (info) => {
                if (info.object) {
                  const props = info.object.properties;
                  const voltage = props.voltage_kv || props.voltage || 'Unknown';
                  const operator = props.operator || 'Unknown operator';
                  const cables = props.cables ? `${props.cables} cables` : '';
                  const frequency = props.frequency ? `${props.frequency} Hz` : '';
                  
                  // Try to get from/to information from tags or geometry
                  let fromTo = '';
                  if (props.from || props.to) {
                    fromTo = `From: ${props.from || '?'} → To: ${props.to || '?'}`;
                  } else if (props.ref) {
                    fromTo = `Line: ${props.ref}`;
                  }
                  
                  const details = [
                    `⚡ ${voltage} kV`,
                    operator,
                    cables,
                    frequency,
                    fromTo
                  ].filter(d => d).join(' • ');
                  
                  setHoveredInfo({
                    name: props.name || 'Power Line',
                    techs: details,
                    x: info.x,
                    y: info.y
                  });
                }
              }
            })] : []),
            // OSM Power Plants Layer
            ...(osmPowerPlants && showOsmLayers.powerPlants && layerVisibility.powerPlants ? [new GeoJsonLayer({
              id: 'osm-power-plants',
              data: {
                ...osmPowerPlants,
                features: osmPowerPlants.features.filter(f => {
                  const props = f.properties;
                  const source = (props.plant_source || props.generator_source || props.source || 'other').toLowerCase();
                  
                  // Check if source is selected
                  const sourceMatch = powerPlantFilters.selectedSources.some(s => source.includes(s));
                  if (!sourceMatch) return false;
                  
                  // Check capacity filter
                  const output = props.generator_output || props.output || props['output:electricity'] || props.capacity || '';
                  if (powerPlantFilters.minCapacity > 0 && output) {
                    const num = parseFloat(output);
                    if (!isNaN(num) && num < powerPlantFilters.minCapacity) return false;
                  }
                  
                  return true;
                })
              },
              pointType: 'circle',
              filled: true,
              stroked: true,
              getPointRadius: d => {
                // Meter-based radius that scales with map zoom
                // At zoom 7: ~5000m, zoom 10: ~1000m, zoom 15: ~30m
                const zoom = viewState.zoom;
                return 150000 / Math.pow(2, zoom);
              },
              radiusUnits: 'meters',
              radiusMinPixels: 3,
              radiusMaxPixels: 30,
              getFillColor: d => {
                const source = (d.properties.plant_source || d.properties.generator_source || '').toLowerCase();
                if (source.includes('solar')) return [255, 215, 0, 220];      // Gold: Solar
                if (source.includes('wind')) return [0, 191, 255, 220];        // Sky blue: Wind
                if (source.includes('hydro')) return [65, 105, 225, 220];      // Royal blue: Hydro
                if (source.includes('nuclear')) return [255, 0, 0, 220];       // Red: Nuclear
                if (source.includes('gas')) return [255, 140, 0, 220];         // Orange: Gas
                if (source.includes('coal')) return [105, 105, 105, 220];      // Dim gray: Coal
                if (source.includes('biomass')) return [34, 139, 34, 220];     // Forest green: Biomass
                if (source.includes('geothermal')) return [255, 69, 0, 220];   // Red-orange: Geothermal
                return [128, 128, 128, 200];                                    // Gray: Unknown
              },
              getLineColor: [0, 0, 0, 255],
              lineWidthMinPixels: 1,
              pickable: true,
              onHover: (info) => {
                if (info.object) {
                  const props = info.object.properties;
                  const source = props.plant_source || props.generator_source || props.source || 'Unknown type';
                  const output = props.generator_output || props.output || props['output:electricity'] || props.capacity || '';
                  const operator = props.operator || 'Unknown operator';
                  
                  // Format capacity
                  let capacityStr = '';
                  if (output) {
                    // Check if it's already formatted with units
                    if (typeof output === 'string' && (output.includes('MW') || output.includes('kW') || output.includes('GW'))) {
                      capacityStr = output;
                    } else {
                      // Assume MW if it's a number
                      const num = parseFloat(output);
                      if (!isNaN(num)) {
                        if (num >= 1000) {
                          capacityStr = `${(num/1000).toFixed(1)} GW`;
                        } else if (num >= 1) {
                          capacityStr = `${num.toFixed(1)} MW`;
                        } else {
                          capacityStr = `${(num*1000).toFixed(0)} kW`;
                        }
                      } else {
                        capacityStr = output;
                      }
                    }
                  }
                  
                  const details = [
                    `🔋 ${source}`,
                    capacityStr,
                    operator
                  ].filter(d => d).join(' • ');
                  
                  setHoveredInfo({
                    name: props.name || 'Power Plant',
                    techs: details,
                    x: info.x,
                    y: info.y
                  });
                }
              }
            })] : []),
            // OSM Substations Layer
            ...(osmSubstations && showOsmLayers.substations && layerVisibility.substations ? [new GeoJsonLayer({
              id: 'osm-substations',
              data: {
                ...osmSubstations,
                features: filteredSubstations
              },
              pointType: 'circle',
              filled: true,
              stroked: true,
              getPointRadius: d => {
                // Meter-based radius that scales with map zoom
                // All substations same size (no voltage multipliers)
                const zoom = viewState.zoom;
                return 150000 / Math.pow(2, zoom);
              },
              radiusUnits: 'meters',
              radiusMinPixels: 3,
              radiusMaxPixels: 30,
              getFillColor: d => {
                const type = (d.properties.substation || 'other').toLowerCase();
                // Red color palette for different substation types
                if (type === 'transmission') return [220, 20, 60, 220];      // Crimson red
                if (type === 'distribution') return [255, 69, 0, 220];       // Red-orange
                if (type === 'converter') return [255, 0, 0, 220];           // Pure red
                if (type === 'traction') return [178, 34, 34, 220];          // Firebrick
                return [139, 0, 0, 220];                                      // Dark red (other)
              },
              getLineColor: [100, 0, 0, 255],
              lineWidthMinPixels: 1,
              pickable: true,
              onHover: (info) => {
                if (info.object) {
                  const props = info.object.properties;
                  const voltage = props.voltage_kv || props.voltage || 'Unknown';
                  const operator = props.operator || 'Unknown operator';
                  const substationType = props.substation || 'Substation';
                  const ref = props.ref ? `[${props.ref}]` : '';
                  
                  // Additional details
                  const location = props.location ? `${props.location}` : '';
                  const frequency = props.frequency ? `${props.frequency} Hz` : '';
                  
                  const details = [
                    `⚡ ${voltage} kV`,
                    substationType.charAt(0).toUpperCase() + substationType.slice(1),
                    operator,
                    frequency,
                    location
                  ].filter(d => d).join(' • ');
                  
                  setHoveredInfo({
                    name: `${props.name || 'Substation'} ${ref}`,
                    techs: details,
                    x: info.x,
                    y: info.y
                  });
                }
              }
            })] : []),
            // OSM Communes Layer
            ...(osmCommunes && showOsmLayers.communes ? [new GeoJsonLayer({
              id: 'osm-communes',
              data: osmCommunes,
              stroked: true,
              filled: true,
              lineWidthMinPixels: 1,
              getFillColor: [200, 200, 200, 30],
              getLineColor: [150, 150, 150, 150],
              pickable: true,
              onHover: (info) => {
                if (info.object) {
                  setHoveredInfo({
                    name: info.object.properties.name || 'Commune',
                    techs: 'Administrative boundary',
                    x: info.x,
                    y: info.y
                  });
                }
              }
            })] : []),
            // OSM Districts Layer
            ...(osmDistricts && showOsmLayers.districts ? [new GeoJsonLayer({
              id: 'osm-districts',
              data: osmDistricts,
              stroked: true,
              filled: true,
              lineWidthMinPixels: 2,
              getFillColor: [100, 100, 255, 20],
              getLineColor: [100, 100, 255, 200],
              pickable: true,
              onHover: (info) => {
                if (info.object) {
                  setHoveredInfo({
                    name: info.object.properties.name || 'District',
                    techs: 'Administrative boundary',
                    x: info.x,
                    y: info.y
                  });
                }
              }
            })] : []),
            // Power Mesh Layers
            ...(generatedMesh && meshVisible ? [
              // Mesh edges (connections between nodes)
              new LineLayer({
                id: 'mesh-edges',
                data: generatedMesh.edges,
                getSourcePosition: edge => {
                  const fromNode = generatedMesh.nodes.find(n => n.id === edge.from);
                  return fromNode ? [fromNode.longitude, fromNode.latitude] : [0, 0];
                },
                getTargetPosition: edge => {
                  const toNode = generatedMesh.nodes.find(n => n.id === edge.to);
                  return toNode ? [toNode.longitude, toNode.latitude] : [0, 0];
                },
                getColor: edge => {
                  // Color by voltage - matching power lines color scheme
                  const voltage = edge.voltage || 0;
                  if (!voltage || voltage === 0) return [30, 144, 255, 220]; // Blue: Unknown
                  
                  // Green to Red gradient based on voltage (matching power lines)
                  if (voltage <= 50) return [0, 255, 0, 220];        // Green: Very low voltage
                  if (voltage <= 110) return [100, 255, 0, 220];     // Yellow-green: Low voltage
                  if (voltage <= 220) return [255, 255, 0, 220];     // Yellow: Medium voltage
                  if (voltage <= 380) return [255, 165, 0, 220];     // Orange: High voltage
                  return [255, 0, 0, 220];                            // Red: Extra high voltage (>380kV)
                },
                getWidth: d => {
                  const baseWidth = infrastructureSizes.powerLines || 1.0;
                  return baseWidth * 1.2;
                },
                widthMinPixels: 1,
                widthMaxPixels: 3,
                pickable: true,
                onHover: (info) => {
                  if (info.object) {
                    const edge = info.object;
                    // Show both distances: straight-line and real OSM distance
                    const distanceInfo = edge.realDistance 
                      ? `Straight: ${edge.distance?.toFixed(2) || '?'} km • Real: ${edge.realDistance?.toFixed(2) || '?'} km`
                      : `${edge.distance?.toFixed(2) || '?'} km`;
                    setHoveredInfo({
                      name: `Connection: ${edge.fromNode?.name || 'Node'} → ${edge.toNode?.name || 'Node'}`,
                      techs: `${distanceInfo} • ${edge.voltage || '?'} kV`,
                      x: info.x,
                      y: info.y
                    });
                  }
                }
              }),
              // Mesh nodes
              new ScatterplotLayer({
                id: 'mesh-nodes',
                data: generatedMesh.nodes,
                getPosition: node => [node.longitude, node.latitude],
                getRadius: node => {
                  // Size matching substations - all same size, no cluster factor
                  const zoom = viewState.zoom;
                  const baseRadius = 150000 / Math.pow(2, zoom);
                  const sizeFactor = infrastructureSizes.substations || 1.0;
                  return baseRadius * sizeFactor;
                },
                radiusUnits: 'meters',
                radiusMinPixels: 3,
                radiusMaxPixels: 30,
                getFillColor: node => {
                  // Single consistent color matching substations (crimson red for transmission)
                  return [220, 20, 60, 220];  // Crimson red - same as transmission substations
                },
                getLineColor: [0, 0, 0, 255],
                lineWidthMinPixels: 1,
                pickable: true,
                onClick: (info) => {
                  if (info.object) {
                    setSelectedMeshNode(info.object);
                    console.log('Selected mesh node:', info.object);
                  }
                },
                onHover: (info) => {
                  if (info.object) {
                    const node = info.object;
                    setHoveredInfo({
                      name: node.name,
                      techs: `${node.voltage || '?'} kV • Cluster: ${node.clusterSize} points`,
                      x: info.x,
                      y: info.y
                    });
                  }
                }
              })
            ] : [])
          ]}
        >
          <MapGL
            mapStyle={MAP_STYLES[currentStyle]}
            attributionControl={false}
          />
        </DeckGL>
        )}

        {/* Hover Tooltip */}
        {hoveredInfo && (
          <div
            style={{
              position: 'absolute',
              left: hoveredInfo.x,
              top: hoveredInfo.y,
              pointerEvents: 'none',
              backgroundColor: 'white',
              padding: '8px 12px',
              borderRadius: '6px',
              boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
              fontSize: '12px',
              zIndex: 1000
            }}
          >
            <div className="font-semibold">{hoveredInfo.name}</div>
            <div className="text-slate-600">{hoveredInfo.techs}</div>
          </div>
        )}

        {/* Mode Indicator */}
        <div className="absolute bottom-4 left-4 bg-white px-4 py-2 rounded-lg shadow-lg">
          <div className="text-xs text-slate-600 mb-1">Current Mode</div>
          <div className="font-semibold text-slate-800">
            {mode === 'single' && 'Single Location'}
            {mode === 'multiple' && 'Multiple Locations'}
            {mode === 'link' && linkStart ? 'Link: Select End Location' : 'Link: Select Start Location'}
          </div>
          {mode === 'link' && linkStart && (
            <div className="text-xs text-gray-600 mt-1">
              From: {linkStart.name}
            </div>
          )}
        </div>
      </div>

      {/* Save Confirmation Dialog */}
      {showSaveDialog && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[10000]">
          <div className="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
            <div className="p-6 border-b border-slate-200">
              <h3 className="text-xl font-bold text-slate-800">Save as New Model</h3>
            </div>
            <div className="p-6 space-y-4">
              {/* Model Name Input */}
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-2">Model Name *</label>
                <input
                  type="text"
                  value={modelConfig.name || modelName}
                  onChange={(e) => {
                    setModelConfig({ ...modelConfig, name: e.target.value });
                    setModelName(e.target.value);
                  }}
                  placeholder="Enter model name..."
                  className="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-500"
                  autoFocus
                />
                <p className="text-xs text-slate-500 mt-1">
                  {modelConfig.name ? 'Using name from Configurations' : 'You can set this in Configurations too'}
                </p>
              </div>

              {/* Summary */}
              <div>
                <p className="text-slate-700 text-sm mb-3">This will create a new model with:</p>
                <ul className="space-y-2 text-sm text-slate-600">
                  <li className="flex items-center gap-2">
                    <FiMapPin className="text-gray-600" />
                    <span><strong>{tempLocations.length}</strong> locations</span>
                  </li>
                  <li className="flex items-center gap-2">
                    <FiLink className="text-gray-600" />
                    <span><strong>{tempLinks.length}</strong> links</span>
                  </li>
                  <li className="flex items-center gap-2">
                    <FiCpu className="text-gray-600" />
                    <span>
                      <strong>
                        {tempLocations.reduce((sum, loc) => sum + Object.keys(loc.techs).length, 0)}
                      </strong> technology assignments
                    </span>
                  </li>
                </ul>
              </div>
            </div>
            <div className="p-6 border-t border-slate-200 flex gap-3 justify-end">
              <button
                onClick={() => {
                  setShowSaveDialog(false);
                  setModelName('');
                }}
                className="px-4 py-2 border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50 transition-colors"
              >
                Cancel
              </button>
              <button
                onClick={saveToMainData}
                disabled={!modelConfig.name?.trim() && !modelName.trim()}
                className="px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors flex items-center gap-2 disabled:bg-slate-300 disabled:cursor-not-allowed"
              >
                <FiCheck size={16} />
                Create Model
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Location Creation Dialog */}
      {showLocationDialog && pendingLocation && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[10000]">
          <div className="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div className="p-6 border-b border-slate-200 sticky top-0 bg-white">
              <h3 className="text-xl font-bold text-slate-800">
                Configure {mode === 'single' ? 'Single' : mode === 'multiple' ? 'Multiple' : ''} Location
              </h3>
              <div className="flex items-center gap-3 mt-2">
                <span className="text-sm text-slate-600">📍</span>
                <input
                  type="number"
                  step="0.0001"
                  value={pendingLocation.latitude}
                  onChange={(e) => setPendingLocation({ ...pendingLocation, latitude: parseFloat(e.target.value) || 0 })}
                  className="w-32 px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                  placeholder="Latitude"
                />
                <span className="text-xs text-slate-400">,</span>
                <input
                  type="number"
                  step="0.0001"
                  value={pendingLocation.longitude}
                  onChange={(e) => setPendingLocation({ ...pendingLocation, longitude: parseFloat(e.target.value) || 0 })}
                  className="w-32 px-2 py-1 text-xs border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-gray-500"
                  placeholder="Longitude"
                />
              </div>
            </div>
            
            <div className="p-6 space-y-6">
              {/* Location Name */}
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-2">Location Name</label>
                <input
                  type="text"
                  value={pendingLocation.name}
                  onChange={(e) => setPendingLocation({ ...pendingLocation, name: e.target.value })}
                  className="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-500"
                  placeholder="Enter location name"
                />
              </div>

              {/* Node Option - Only for Single Location Mode */}
              {mode === 'single' && (
                <div className="flex items-center gap-3 p-4 bg-slate-50 rounded-lg">
                  <input
                    type="checkbox"
                    id="isNode"
                    checked={isNode}
                    onChange={(e) => handleNodeCheckboxChange(e.target.checked)}
                    className="w-4 h-4 text-gray-600 border-slate-300 rounded focus:ring-gray-500"
                  />
                  <label htmlFor="isNode" className="text-sm font-medium text-slate-700">
                    This is a node (connection point without technologies)
                  </label>
                </div>
              )}

              {/* Technologies Selection */}
              {!isNode && (
                <div>
                  <div className="flex items-center justify-between mb-3">
                    <label className="block text-sm font-medium text-slate-700">
                      Technologies ({dialogTechs.length} selected)
                    </label>
                    {mode === 'single' && dialogTechs.length === 1 && (
                      <button
                        onClick={() => setMode('multiple')}
                        className="px-3 py-1 text-xs bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors flex items-center gap-1"
                      >
                        <FiCpu size={12} />
                        Add More Techs
                      </button>
                    )}
                  </div>
                  
                  {/* Selected Technologies */}
                  {dialogTechs.length > 0 && (
                    <div className="space-y-2 mb-4 p-3 bg-gray-50 rounded-lg border border-gray-200">
                      {dialogTechs.map(techName => {
                        const techTemplate = techMap[techName];
                        const customConstraints = editingConstraints[techName] || {};
                        const allConstraints = { ...techTemplate?.constraints, ...customConstraints };
                        const isExpanded = expandedTechConstraints[techName];
                        const csvFile = techCsvFiles[techName];
                        
                        return (
                          <div key={techName} className="bg-white rounded-lg p-3 border border-gray-300">
                            <div className="flex items-center justify-between">
                              <span className="font-medium text-slate-800">{formatTechName(techName)}</span>
                              <div className="flex items-center gap-2">
                                <button
                                  onClick={() => toggleTechConstraints(techName)}
                                  className="text-slate-600 hover:text-slate-800 text-xs flex items-center gap-1"
                                >
                                  {isExpanded ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                                  <span>Edit</span>
                                </button>
                                <button
                                  onClick={() => removeTechFromDialog(techName)}
                                  className="text-gray-500 hover:text-gray-700"
                                >
                                  <FiTrash2 size={16} />
                                </button>
                              </div>
                            </div>

                            {/* Demand Value or CSV Upload - Mandatory for demand technologies */}
                            {techTemplate?.parent === 'demand' && (
                              <div className="mt-2 p-3 bg-gray-50 border border-gray-200 rounded-lg">
                                <label className="block text-xs font-semibold text-gray-800 mb-2">
                                  Energy Demand * (Required)
                                </label>
                                <input
                                  type="text"
                                  value={editingConstraints[techName]?.energy_cap || ''}
                                  onChange={(e) => updateDialogConstraint(techName, 'energy_cap', e.target.value)}
                                  placeholder="Enter demand value (kW) or upload CSV below"
                                  className="w-full px-2 py-1.5 text-xs border border-gray-300 rounded focus:ring-2 focus:ring-gray-500 mb-2"
                                />
                                <label className="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                                  <span>Or upload timeseries CSV:</span>
                                  <input
                                    type="file"
                                    accept=".csv"
                                    onChange={(e) => handleTechCsvUpload(techName, e.target.files[0])}
                                    className="text-xs"
                                  />
                                </label>
                                {csvFile && (
                                  <p className="text-xs text-gray-600 mt-1">✓ {csvFile.name}</p>
                                )}
                              </div>
                            )}
                            
                            {/* Production/Consumption CSV - Optional for non-demand technologies */}
                            {techTemplate?.parent !== 'demand' && (
                              <div className="mt-2">
                                <label className="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                                  <span>Production/Consumption CSV:</span>
                                  <input
                                    type="file"
                                    accept=".csv"
                                    onChange={(e) => handleTechCsvUpload(techName, e.target.files[0])}
                                    className="text-xs"
                                  />
                                </label>
                                {csvFile && (
                                  <p className="text-xs text-gray-600 mt-1">✓ {csvFile.name}</p>
                                )}
                              </div>
                            )}
                            
                            {/* Collapsible Tech Editor */}
                            {isExpanded && (
                              <div className="mt-3 pt-3 border-t border-slate-200 space-y-4">
                                {/* Essentials Section - Editable */}
                                <div>
                                  <button
                                    onClick={() => setExpandedSections({ ...expandedSections, [`${techName}_essentials`]: !expandedSections[`${techName}_essentials`] })}
                                    className="flex items-center gap-2 text-xs font-semibold text-slate-700 mb-2 hover:text-gray-600"
                                  >
                                    {expandedSections[`${techName}_essentials`] ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                                    <span>Essentials</span>
                                  </button>
                                  {expandedSections[`${techName}_essentials`] && (
                                    <div className="pl-4 space-y-2">
                                      {/* Editable Essentials */}
                                      {Object.entries(techTemplate?.essentials || {}).map(([key, value]) => {
                                        const customValue = editingEssentials[techName]?.[key];
                                        const displayValue = customValue !== undefined ? customValue : value;
                                        const definition = ESSENTIAL_DEFINITIONS[key];
                                        
                                        return (
                                          <div key={key} className="flex gap-2 items-center">
                                            <div className="flex items-center gap-1 w-28">
                                              <span className="text-slate-600 text-xs">{formatTechName(key)}:</span>
                                              {definition && (
                                                <div className="relative group">
                                                  <FiHelpCircle size={12} className="text-slate-400 cursor-help" />
                                                  <div className="absolute left-0 bottom-full mb-1 hidden group-hover:block w-48 p-2 bg-slate-800 text-white text-xs rounded shadow-lg z-50">
                                                    {definition.desc}
                                                  </div>
                                                </div>
                                              )}
                                            </div>
                                            {key === 'color' ? (
                                              <div className="flex items-center gap-2 flex-1">
                                                <input
                                                  type="color"
                                                  value={displayValue}
                                                  onChange={(e) => updateDialogEssential(techName, key, e.target.value)}
                                                  className="w-8 h-6 border border-slate-300 rounded cursor-pointer"
                                                />
                                                <input
                                                  type="text"
                                                  value={displayValue}
                                                  onChange={(e) => updateDialogEssential(techName, key, e.target.value)}
                                                  className="flex-1 px-2 py-1 text-xs border border-slate-300 rounded focus:ring-2 focus:ring-gray-500"
                                                />
                                              </div>
                                            ) : key === 'parent' ? (
                                              <span className="text-xs font-medium text-slate-800">{displayValue}</span>
                                            ) : (
                                              <input
                                                type="text"
                                                value={displayValue}
                                                onChange={(e) => updateDialogEssential(techName, key, e.target.value)}
                                                className="flex-1 px-2 py-1 text-xs border border-slate-300 rounded focus:ring-2 focus:ring-gray-500"
                                              />
                                            )}
                                          </div>
                                        );
                                      })}
                                    </div>
                                  )}
                                </div>

                                {/* Constraints Section */}
                                <div>
                                  <button
                                    onClick={() => setExpandedSections({ ...expandedSections, [`${techName}_constraints`]: !expandedSections[`${techName}_constraints`] })}
                                    className="flex items-center gap-2 text-xs font-semibold text-slate-700 mb-2 hover:text-gray-600"
                                  >
                                    {expandedSections[`${techName}_constraints`] ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                                    <span>Constraints ({Object.keys(allConstraints).length})</span>
                                  </button>
                                  {expandedSections[`${techName}_constraints`] && (
                                    <div className="pl-4 space-y-3">
                                      {/* Existing Constraints - Simple List with Tooltips */}
                                      {Object.keys(allConstraints).length > 0 && (
                                        <div className="space-y-2">
                                          {Object.entries(allConstraints).map(([key, value]) => {
                                            const definition = CONSTRAINT_DEFINITIONS[key];
                                            const fileKey = `${techName}_${key}`;
                                            const csvFile = constraintCsvFiles[fileKey];
                                            const isResourceConstraint = key === 'resource';
                                            
                                            return (
                                              <div key={key} className="space-y-2">
                                                <div className="flex gap-2 items-center">
                                                  <div className="flex items-center gap-1 min-w-0 flex-1">
                                                    <input
                                                      type="text"
                                                      value={key}
                                                      disabled
                                                      className="flex-1 px-2 py-1 text-xs border border-slate-300 rounded bg-slate-50"
                                                    />
                                                    {definition && (
                                                      <div className="relative group flex-shrink-0">
                                                        <FiHelpCircle size={14} className="text-slate-400 cursor-help" />
                                                        <div className="absolute left-0 bottom-full mb-1 hidden group-hover:block w-56 p-2 bg-slate-800 text-white text-xs rounded shadow-lg z-50">
                                                          {definition.desc}
                                                        </div>
                                                      </div>
                                                    )}
                                                  </div>
                                                  <input
                                                    type="text"
                                                    value={typeof value === 'object' ? JSON.stringify(value) : value}
                                                    onChange={(e) => updateDialogConstraint(techName, key, e.target.value)}
                                                    className="flex-1 px-2 py-1 text-xs border border-slate-300 rounded focus:ring-2 focus:ring-gray-500"
                                                    placeholder={isResourceConstraint ? "Value or upload CSV below" : "Value"}
                                                  />
                                                </div>
                                                
                                                {/* File upload for resource constraint */}
                                                {isResourceConstraint && (
                                                  <div className="pl-4 mt-1">
                                                    <label className="flex items-center gap-2 text-xs text-slate-600 cursor-pointer">
                                                      <span>Or upload timeseries CSV:</span>
                                                      <input
                                                        type="file"
                                                        accept=".csv"
                                                        onChange={(e) => handleConstraintCsvUpload(techName, key, e.target.files[0])}
                                                        className="text-xs"
                                                      />
                                                    </label>
                                                    {csvFile && (
                                                      <p className="text-xs text-gray-600 mt-1">✓ {csvFile.name}</p>
                                                    )}
                                                  </div>
                                                )}
                                              </div>
                                            );
                                          })}
                                        </div>
                                      )}
                                      
                                      {/* Add Constraint Button - Animated */}
                                      <div className="pt-2 border-t border-slate-200">
                                        <button
                                          onClick={() => setConstraintSearch({ ...constraintSearch, [techName]: 'open' })}
                                          className="group flex h-9 w-full items-center gap-2 rounded-full bg-gray-200 pl-3 pr-4 transition-all duration-300 ease-in-out hover:bg-gray-600 hover:pl-2 hover:text-white active:bg-gray-700 text-sm font-medium text-gray-800"
                                        >
                                          <span className="rounded-full bg-gray-600 p-1 text-sm transition-colors duration-300 group-hover:bg-white">
                                            <FiArrowRight className="-translate-x-[200%] text-[0px] transition-all duration-300 group-hover:translate-x-0 group-hover:text-base group-hover:text-gray-600" />
                                          </span>
                                          <span>Add Constraint</span>
                                        </button>
                                      </div>
                                      
                                      {/* Constraint Browser Modal */}
                                      {constraintSearch[techName] === 'open' && (
                                        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[10001]" onClick={() => setConstraintSearch({ ...constraintSearch, [techName]: '' })}>
                                          <div className="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[80vh] overflow-hidden" onClick={(e) => e.stopPropagation()}>
                                            <div className="p-4 border-b border-slate-200 bg-gray-600 text-white">
                                              <h3 className="text-lg font-bold">Available Constraints for {formatTechName(techTemplate?.parent || '')}</h3>
                                              <p className="text-xs text-gray-100 mt-1">Browse by category and click to add</p>
                                            </div>
                                            <div className="overflow-y-auto max-h-[calc(80vh-120px)]">
                                              {(() => {
                                                const available = PARENT_CONSTRAINTS[techTemplate?.parent]?.filter(c => !allConstraints[c]) || [];
                                                
                                                if (available.length === 0) {
                                                  return (
                                                    <div className="p-8 text-center text-slate-500">
                                                      <p className="text-sm">All available constraints have been added.</p>
                                                    </div>
                                                  );
                                                }
                                                
                                                // Group available constraints
                                                const groupedAvailable = {};
                                                available.forEach(constraint => {
                                                  const group = CONSTRAINT_DEFINITIONS[constraint]?.group || 'Other';
                                                  if (!groupedAvailable[group]) groupedAvailable[group] = [];
                                                  groupedAvailable[group].push(constraint);
                                                });
                                                
                                                return Object.entries(groupedAvailable).map(([group, constraints]) => {
                                                  if (!constraints || constraints.length === 0) return null;
                                                  
                                                  const isExpanded = selectedConstraintGroup[`${techName}_${group}`];
                                                  
                                                  return (
                                                    <div key={group} className="border-b border-slate-200 last:border-b-0">
                                                      <button
                                                        onClick={() => setSelectedConstraintGroup({ 
                                                          ...selectedConstraintGroup, 
                                                          [`${techName}_${group}`]: !isExpanded 
                                                        })}
                                                        className="w-full flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 transition-colors"
                                                      >
                                                        <span className="text-sm font-semibold text-gray-900">
                                                          {formatTechName(group)} ({constraints.length})
                                                        </span>
                                                        {isExpanded ? <FiChevronDown size={16} className="text-gray-600" /> : <FiChevronRight size={16} className="text-gray-600" />}
                                                      </button>
                                                      {isExpanded && (
                                                        <div className="divide-y divide-slate-100 bg-white">
                                                          {constraints.map(constraint => {
                                                            const definition = CONSTRAINT_DEFINITIONS[constraint];
                                                            return (
                                                              <button
                                                                key={constraint}
                                                                onClick={() => {
                                                                  updateDialogConstraint(techName, constraint, '');
                                                                  setConstraintSearch({ ...constraintSearch, [techName]: '' });
                                                                  setSelectedConstraintGroup({});
                                                                }}
                                                                className="w-full text-left px-6 py-3 hover:bg-gray-50 transition-colors"
                                                              >
                                                                <div className="font-medium text-slate-800 text-sm mb-1">{formatTechName(constraint)}</div>
                                                                {definition && (
                                                                  <div className="text-slate-600 text-xs leading-relaxed">
                                                                    {definition.desc}
                                                                  </div>
                                                                )}
                                                              </button>
                                                            );
                                                          })}
                                                        </div>
                                                      )}
                                                    </div>
                                                  );
                                                });
                                              })()}
                                            </div>
                                            <div className="p-4 border-t border-slate-200 bg-slate-50">
                                              <button
                                                onClick={() => {
                                                  setConstraintSearch({ ...constraintSearch, [techName]: '' });
                                                  setSelectedConstraintGroup({});
                                                }}
                                                className="w-full px-4 py-2 bg-slate-600 text-white rounded hover:bg-slate-700 transition-colors"
                                              >
                                                Close
                                              </button>
                                            </div>
                                          </div>
                                        </div>
                                      )}
                                    </div>
                                  )}
                                </div>

                                {/* Costs Section - Editable */}
                                <div>
                                  <button
                                    onClick={() => setExpandedSections({ ...expandedSections, [`${techName}_costs`]: !expandedSections[`${techName}_costs`] })}
                                    className="flex items-center gap-2 text-xs font-semibold text-slate-700 mb-2 hover:text-gray-600"
                                  >
                                    {expandedSections[`${techName}_costs`] ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                                    <span>Costs</span>
                                  </button>
                                  {expandedSections[`${techName}_costs`] && (
                                    <div className="pl-4 space-y-3">
                                      {/* Existing Costs - Simple List with Tooltips */}
                                      {(() => {
                                        const monetaryCosts = techTemplate?.costs?.monetary || {};
                                        const customCosts = editingCosts[techName] || {};
                                        const allCosts = { ...monetaryCosts, ...customCosts };
                                        
                                        if (Object.keys(allCosts).length === 0) {
                                          return <p className="text-slate-500 italic text-xs">No costs defined. Use the search below to add costs.</p>;
                                        }
                                        
                                        return (
                                          <div className="space-y-2">
                                            {Object.entries(allCosts).map(([key, value]) => {
                                              const definition = COST_DEFINITIONS[key];
                                              const customValue = editingCosts[techName]?.[key];
                                              const displayValue = customValue !== undefined ? customValue : value;
                                              
                                              return (
                                                <div key={key} className="flex gap-2 items-center">
                                                  <div className="flex items-center gap-1 min-w-0 flex-1">
                                                    <span className="text-xs text-slate-600 flex-1">{key}:</span>
                                                    {definition && (
                                                      <div className="relative group flex-shrink-0">
                                                        <FiHelpCircle size={14} className="text-slate-400 cursor-help" />
                                                        <div className="absolute left-0 bottom-full mb-1 hidden group-hover:block w-56 p-2 bg-slate-800 text-white text-xs rounded shadow-lg z-50">
                                                          {definition.desc}
                                                        </div>
                                                      </div>
                                                    )}
                                                  </div>
                                                  <input
                                                    type="number"
                                                    step="any"
                                                    value={displayValue}
                                                    onChange={(e) => updateDialogCost(techName, key, e.target.value)}
                                                    className="w-28 px-2 py-1 text-xs border border-slate-300 rounded focus:ring-2 focus:ring-gray-500"
                                                  />
                                                </div>
                                              );
                                            })}
                                          </div>
                                        );
                                      })()}
                                      
                                      {/* Add Cost Button - Animated */}
                                      <div className="pt-2 border-t border-slate-200">
                                        <button
                                          onClick={() => setCostSearch({ ...costSearch, [techName]: 'open' })}
                                          className="group flex h-9 w-full items-center gap-2 rounded-full bg-gray-200 pl-3 pr-4 transition-all duration-300 ease-in-out hover:bg-gray-600 hover:pl-2 hover:text-white active:bg-gray-700 text-sm font-medium text-gray-800"
                                        >
                                          <span className="rounded-full bg-gray-600 p-1 text-sm transition-colors duration-300 group-hover:bg-white">
                                            <FiArrowRight className="-translate-x-[200%] text-[0px] transition-all duration-300 group-hover:translate-x-0 group-hover:text-base group-hover:text-gray-600" />
                                          </span>
                                          <span>Add Cost</span>
                                        </button>
                                      </div>
                                      
                                      {/* Cost Browser Modal */}
                                      {costSearch[techName] === 'open' && (
                                        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[10001]" onClick={() => setCostSearch({ ...costSearch, [techName]: '' })}>
                                          <div className="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[80vh] overflow-hidden" onClick={(e) => e.stopPropagation()}>
                                            <div className="p-4 border-b border-slate-200 bg-gray-600 text-white">
                                              <h3 className="text-lg font-bold">Available Costs</h3>
                                              <p className="text-xs text-gray-100 mt-1">Browse by category and click to add</p>
                                            </div>
                                            <div className="overflow-y-auto max-h-[calc(80vh-120px)]">
                                              {(() => {
                                                const allCosts = { ...(techTemplate?.costs?.monetary || {}), ...(editingCosts[techName] || {}) };
                                                const available = Object.keys(COST_DEFINITIONS).filter(c => !allCosts[c]);
                                                
                                                if (available.length === 0) {
                                                  return (
                                                    <div className="p-8 text-center text-slate-500">
                                                      <p className="text-sm">All available costs have been added.</p>
                                                    </div>
                                                  );
                                                }
                                                
                                                // Group available costs
                                                const groupedAvailable = {};
                                                available.forEach(cost => {
                                                  const group = COST_DEFINITIONS[cost]?.group || 'Other';
                                                  if (!groupedAvailable[group]) groupedAvailable[group] = [];
                                                  groupedAvailable[group].push(cost);
                                                });
                                                
                                                return Object.entries(groupedAvailable).map(([group, costs]) => {
                                                  if (!costs || costs.length === 0) return null;
                                                  
                                                  const isExpanded = selectedCostGroup[`${techName}_${group}`];
                                                  
                                                  return (
                                                    <div key={group} className="border-b border-slate-200 last:border-b-0">
                                                      <button
                                                        onClick={() => setSelectedCostGroup({ 
                                                          ...selectedCostGroup, 
                                                          [`${techName}_${group}`]: !isExpanded 
                                                        })}
                                                        className="w-full flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 transition-colors"
                                                      >
                                                        <span className="text-sm font-semibold text-gray-900">
                                                          {formatTechName(group)} ({costs.length})
                                                        </span>
                                                        {isExpanded ? <FiChevronDown size={16} className="text-gray-600" /> : <FiChevronRight size={16} className="text-gray-600" />}
                                                      </button>
                                                      {isExpanded && (
                                                        <div className="divide-y divide-slate-100 bg-white">
                                                          {costs.map(cost => {
                                                            const definition = COST_DEFINITIONS[cost];
                                                            return (
                                                              <button
                                                                key={cost}
                                                                onClick={() => {
                                                                  updateDialogCost(techName, cost, 0);
                                                                  setCostSearch({ ...costSearch, [techName]: '' });
                                                                  setSelectedCostGroup({});
                                                                }}
                                                                className="w-full text-left px-6 py-3 hover:bg-gray-50 transition-colors"
                                                              >
                                                                <div className="font-medium text-slate-800 text-sm mb-1">{formatTechName(cost)}</div>
                                                                {definition && (
                                                                  <div className="text-slate-600 text-xs leading-relaxed">
                                                                    {definition.desc}
                                                                  </div>
                                                                )}
                                                              </button>
                                                            );
                                                          })}
                                                        </div>
                                                      )}
                                                    </div>
                                                  );
                                                });
                                              })()}
                                            </div>
                                            <div className="p-4 border-t border-slate-200 bg-slate-50">
                                              <button
                                                onClick={() => {
                                                  setCostSearch({ ...costSearch, [techName]: '' });
                                                  setSelectedCostGroup({});
                                                }}
                                                className="w-full px-4 py-2 bg-slate-600 text-white rounded hover:bg-slate-700 transition-colors"
                                              >
                                                Close
                                              </button>
                                            </div>
                                          </div>
                                        </div>
                                      )}
                                    </div>
                                  )}
                                </div>
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  )}

                  {/* Available Technologies */}
                  <div className="max-h-96 overflow-y-auto border border-slate-200 rounded-lg p-3">
                    <p className="text-xs font-semibold text-slate-600 mb-3">
                      Available Technologies ({Object.keys(techMap).length})
                    </p>
                    {Object.keys(techMap).length === 0 ? (
                      <div className="text-center py-8 text-slate-500 text-sm">
                        <p>No technologies available.</p>
                        <p className="text-xs mt-2">Load a model or add technologies in the Technologies section.</p>
                      </div>
                    ) : (
                      <div className="space-y-2">
                        {/* Group technologies by parent type */}
                        {['supply', 'supply_plus', 'demand', 'storage', 'conversion', 'conversion_plus'].map(parentType => {
                          const techsInCategory = Object.entries(techMap).filter(([name, tech]) => tech.parent === parentType);
                          
                          if (techsInCategory.length === 0) return null;
                          
                          const isExpanded = expandedCategories[`dialog_${parentType}`];
                          
                          return (
                            <div key={parentType} className="border border-slate-200 rounded-lg overflow-hidden">
                              <button
                                onClick={() => toggleCategory(`dialog_${parentType}`)}
                                className="w-full flex items-center justify-between px-3 py-2 bg-slate-50 hover:bg-slate-100 transition-colors"
                              >
                                <span className="text-xs font-bold text-slate-700 uppercase tracking-wide">
                                  {formatTechName(parentType)} ({techsInCategory.length})
                                </span>
                                {isExpanded ? <FiChevronDown size={14} /> : <FiChevronRight size={14} />}
                              </button>
                              
                              {isExpanded && (
                                <div className="p-2 bg-white">
                                  <div className="grid grid-cols-2 gap-2">
                                    {techsInCategory.map(([techName, tech]) => {
                                      const isSelected = dialogTechs.includes(techName);
                                      return (
                                        <button
                                          key={techName}
                                          onClick={() => !isSelected && addTechToDialog(techName)}
                                          disabled={isSelected}
                                          className={`p-2 rounded text-xs text-left transition-colors ${
                                            isSelected
                                              ? 'bg-slate-100 text-slate-400 cursor-not-allowed'
                                              : 'bg-slate-50 hover:bg-gray-50 text-slate-700 hover:text-gray-700 border border-slate-200'
                                          }`}
                                          title={tech.description || techName}
                                        >
                                          {isSelected ? '✓ ' : '+ '}{formatTechName(techName)}
                                        </button>
                                      );
                                    })}
                                  </div>
                                </div>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>

            <div className="p-6 border-t border-slate-200 flex gap-3 justify-end sticky bottom-0 bg-white">
              <button
                onClick={() => {
                  setShowLocationDialog(false);
                  setPendingLocation(null);
                  setOriginalLocationData(null);
                  setDialogTechs([]);
                  setEditingConstraints({});
                }}
                className="px-4 py-2 border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50 transition-colors"
              >
                Cancel
              </button>
              <button
                onClick={confirmLocationCreation}
                disabled={originalLocationData && !hasLocationChanged()}
                className="px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors flex items-center gap-2 disabled:bg-slate-300 disabled:cursor-not-allowed"
              >
                <FiCheck size={16} />
                {originalLocationData ? 'Update Location' : 'Create Location'}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Node Conversion Confirmation Dialog */}
      {showNodeConfirmDialog && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[10001]">
          <div className="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
            <div className="p-6 border-b border-slate-200">
              <div className="flex items-center gap-3">
                <div className="flex-shrink-0 w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center">
                  <span className="text-2xl">⚠️</span>
                </div>
                <h3 className="text-xl font-bold text-slate-800">Convert to Node?</h3>
              </div>
            </div>
            <div className="p-6 space-y-4">
              <p className="text-sm text-slate-700">
                A node is a connection point without technologies.
              </p>
              <div className="p-4 bg-gray-50 border border-gray-200 rounded-lg">
                <p className="text-sm font-semibold text-gray-800 mb-2">
                  This will permanently remove {dialogTechs.length} technolog{dialogTechs.length === 1 ? 'y' : 'ies'} and all associated configurations:
                </p>
                <ul className="space-y-1 max-h-40 overflow-y-auto">
                  {dialogTechs.map(techName => (
                    <li key={techName} className="text-sm text-gray-700 flex items-start gap-2">
                      <span className="text-gray-500 mt-0.5">•</span>
                      <span>{formatTechName(techName)}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <p className="text-xs text-slate-600 italic">
                This action cannot be undone. All constraints, costs, and CSV files will be lost.
              </p>
            </div>
            <div className="p-6 border-t border-slate-200 flex gap-3 justify-end">
              <button
                onClick={() => setShowNodeConfirmDialog(false)}
                className="px-4 py-2 border border-slate-300 text-slate-700 rounded-md hover:bg-slate-50 transition-colors"
              >
                Cancel
              </button>
              <button
                onClick={confirmNodeConversion}
                className="px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 transition-colors flex items-center gap-2"
              >
                <FiTrash2 size={16} />
                Convert to Node
              </button>
            </div>
          </div>
        </div>
      )}
      
      {/* OSM Infrastructure Panel - Right Sidebar */}
      <OsmInfrastructurePanel
        collapsed={rightSidebarCollapsed}
        onToggleCollapse={() => setRightSidebarCollapsed(!rightSidebarCollapsed)}
        showOsmLayers={showOsmLayers}
        onOsmLayersChange={setShowOsmLayers}
        infrastructureSizes={infrastructureSizes}
        onInfrastructureSizesChange={setInfrastructureSizes}
        onRegionSelect={handleRegionSelect}
        powerLineFilters={powerLineFilters}
        onPowerLineFiltersChange={setPowerLineFilters}
        powerPlantFilters={powerPlantFilters}
        onPowerPlantFiltersChange={setPowerPlantFilters}
        substationFilters={substationFilters}
        onSubstationFiltersChange={setSubstationFilters}
      />
    </div>
  );
};

export default Creation;
