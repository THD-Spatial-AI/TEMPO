
# H2 simulation service (remote VM or local Docker)
VITE_H2_SERVICE_URL=http://10.1.66.27:8765

# CCS simulation service (leave empty to use local Docker on :8766)
VITE_CCS_SERVICE_URL=

# opentech-db public API URL.
# Leave empty to use local Docker on :8000.
# Set to the deployed URL once the public instance is up, e.g.:
#   VITE_TECH_API_URL=https://opentech.tempo-tool.eu
# In packaged Electron builds, set TEMPO_TECH_API_URL instead (env var read by the main process).
VITE_TECH_API_URL=

