# ─────────────────────────────────────────────────────────────────────────────
# Calliope Visualizator — environment variables
# Copy this file to .env and fill in the values for your setup.
# ─────────────────────────────────────────────────────────────────────────────

# ── Hydrogen Plant Simulation VM ─────────────────────────────────────────────
# URL of the FastAPI MATLAB Bridge running on the dedicated simulation VM.
# The service lives in a SEPARATE repository — see hydrogen_vm_prompt.txt
# for instructions on setting it up.
#
# Examples:
#   Local dev (VM port-forwarded to localhost):  http://localhost:8765
#   Direct VM address:                           http://192.168.1.50:8765
#   VM behind reverse proxy (HTTPS):             https://h2-sim.internal:443
#
VITE_H2_SERVICE_URL=http://10.1.66.27:8765

# ── OpenTech-DB Technology Catalog API ───────────────────────────────────────
# Default is the hosted public ngrok instance (no setup required).
# Override only if you are running opentech-db locally or via Docker.
#
# Examples:
#   Local Python/conda:  http://localhost:8000
#   Local via Vite proxy (add /tech proxy in vite.config.js): /tech
#   Hosted (default — leave unset or set explicitly):
#     https://marleigh-unmuttering-effortlessly.ngrok-free.dev
#
# VITE_TECH_API_URL=http://localhost:8000